{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Full stack developer, open-source enthusiast, and a minimalist",
  "license": "MIT",
  "author": "Guy Romelle Magayano <aspiredtechie2010@gmail.com> (https://www.guyromellemagayano.com)",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:affected": "turbo run build --affected",
    "build:packages": "pnpm build --filter=\"@portfolio/*\"",
    "check-types": "turbo run check-types",
    "check-types:affected": "turbo run check-types --affected",
    "ci:affected": "turbo run lint lint:styles check-types test:run --affected",
    "clean": "turbo run clean",
    "commit": "NPM_CONFIG_LOGLEVEL=error czg gpg",
    "commit:retry": "git commit --amend --no-edit",
    "dev": "turbo run dev --parallel --output-logs=full",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "lint": "turbo run lint && pnpm run lint:styles",
    "lint:affected": "turbo run lint --affected && pnpm run lint:styles:affected",
    "lint:ci": "pnpm run lint && turbo run check-types",
    "lint:fix": "turbo run lint:fix && pnpm run lint:styles:fix",
    "lint:styles": "turbo run lint:styles --filter=web --filter=@portfolio/components --filter=@portfolio/ui",
    "lint:styles:affected": "turbo run lint:styles --affected --filter=web --filter=@portfolio/components --filter=@portfolio/ui",
    "lint:styles:fix": "turbo run lint:styles:fix --filter=web --filter=@portfolio/components --filter=@portfolio/ui",
    "pcu": "pnpm exec pcu",
    "pcu:check": "pnpm run pcu check",
    "pcu:security": "pnpm run pcu security",
    "pcu:security:fix": "pnpm run pcu:security --fix-vulns",
    "pcu:update": "pnpm run pcu update",
    "prepare": "husky",
    "test": "turbo run test:run",
    "test:affected": "turbo run test:run --affected",
    "test:apps": "turbo run test:run --filter='./apps/*'",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:apps": "turbo run test:run:coverage --filter='./apps/*'",
    "test:coverage:packages": "turbo run test:run:coverage --filter='./packages/*'",
    "test:coverage:ui": "turbo run test:coverage:ui",
    "test:e2e": "pnpm --filter e2e test:e2e",
    "test:e2e:headed": "pnpm --filter e2e test:e2e:headed",
    "test:e2e:install": "pnpm --filter e2e test:e2e:install",
    "test:e2e:install:ci": "pnpm --filter e2e test:e2e:install:ci",
    "test:e2e:report": "pnpm --filter e2e test:e2e:report",
    "test:e2e:smoke": "pnpm --filter e2e test:e2e:smoke",
    "test:e2e:ui": "pnpm --filter e2e test:e2e:ui",
    "test:packages": "turbo run test:run --filter='./packages/*'",
    "test:run": "turbo run test:run",
    "test:run:coverage": "turbo run test:run:coverage",
    "test:ui": "turbo run test:ui",
    "test:watch": "turbo run test --parallel"
  },
  "dependencies": {
    "pnpm-catalog-updates": "catalog:"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/types": "catalog:",
    "@portfolio/config-eslint": "workspace:*",
    "@portfolio/config-typescript": "workspace:*",
    "@portfolio/vitest-presets": "workspace:*",
    "@tailwindcss/typography": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "czg": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-astro": "catalog:",
    "prettier-plugin-packagejson": "catalog:",
    "prettier-plugin-pkg": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-standard": "catalog:",
    "tailwindcss": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "validate-branch-name": "catalog:"
  },
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-react-hooks>eslint": "^10.0.0"
      }
    },
    "overrides": {
      "@csstools/css-calc": "3.1.1",
      "ajv@<6.14.0": "6.12.6",
      "minimatch@<10.2.1": ">=10.2.1"
    }
  }
}
