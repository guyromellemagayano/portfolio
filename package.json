{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Full stack developer, open-source enthusiast, and a minimalist",
  "license": "MIT",
  "author": "Guy Romelle Magayano <aspiredtechie2010@gmail.com> (https://www.guyromellemagayano.com)",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:affected": "turbo run build --affected",
    "build:apps": "turbo run build --filter='./apps/*'",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:web": "turbo run build --filter=web",
    "check-types": "turbo run check-types",
    "check-types:affected": "turbo run check-types --affected",
    "check-types:apps": "turbo run check-types --filter='./apps/*'",
    "check-types:packages": "turbo run check-types --filter='./packages/*'",
    "check-types:web": "turbo run check-types --filter=web",
    "ci:affected": "turbo run lint lint:styles check-types test:run --affected",
    "clean": "turbo run clean",
    "commit": "pnpm exec portfolio-commit gpg",
    "commit:retry": "git commit --amend --no-edit",
    "deploy:web": "pnpm build:web && vercel deploy apps/web",
    "deploy:web:prod": "pnpm build:web && vercel deploy apps/web --prod",
    "dev": "pnpm dev:docker",
    "dev:docker": "docker compose up --build web",
    "dev:docker:detached": "docker compose up --build --detach web",
    "dev:docker:down": "docker compose down --remove-orphans",
    "dev:docker:logs": "docker compose logs --follow web",
    "dev:host": "turbo run dev --output-logs=full",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "lighthouse:ci": "pnpm build:web && lhci autorun",
    "lint": "turbo run lint lint:styles",
    "lint:affected": "turbo run lint lint:styles --affected",
    "lint:apps": "turbo run lint lint:styles --filter='./apps/*'",
    "lint:ci": "turbo run lint lint:styles check-types",
    "lint:fix": "turbo run lint:fix lint:styles:fix",
    "lint:packages": "turbo run lint lint:styles --filter='./packages/*'",
    "lint:styles": "turbo run lint:styles",
    "lint:styles:affected": "turbo run lint:styles --affected",
    "lint:styles:fix": "turbo run lint:styles:fix",
    "lint:web": "turbo run lint lint:styles --filter=web",
    "pcu": "pnpm exec pcu",
    "pcu:check": "pnpm run pcu check",
    "pcu:security": "pnpm run pcu security",
    "pcu:security:fix": "pnpm run pcu:security --fix-vulns",
    "pcu:update": "pnpm run pcu update",
    "prepare": "husky",
    "test": "turbo run test:run",
    "test:affected": "turbo run test:run --affected",
    "test:apps": "turbo run test:run --filter='./apps/*'",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:apps": "turbo run test:run:coverage --filter='./apps/*'",
    "test:coverage:packages": "turbo run test:run:coverage --filter='./packages/*'",
    "test:coverage:ui": "turbo run test:coverage:ui",
    "test:e2e": "turbo run test:e2e --filter=e2e",
    "test:e2e:headed": "turbo run test:e2e:headed --filter=e2e",
    "test:e2e:install": "turbo run test:e2e:install --filter=e2e",
    "test:e2e:install:ci": "turbo run test:e2e:install:ci --filter=e2e",
    "test:e2e:report": "turbo run test:e2e:report --filter=e2e",
    "test:e2e:smoke": "turbo run test:e2e:smoke --filter=e2e",
    "test:e2e:ui": "turbo run test:e2e:ui --filter=e2e",
    "test:packages": "turbo run test:run --filter='./packages/*'",
    "test:run": "turbo run test:run",
    "test:run:coverage": "turbo run test:run:coverage",
    "test:ui": "turbo run test:ui",
    "test:watch": "turbo watch test:run",
    "test:web": "turbo run test:run --filter=web"
  },
  "dependencies": {
    "pnpm-catalog-updates": "catalog:"
  },
  "devDependencies": {
    "@lhci/cli": "catalog:",
    "@portfolio/config-commit": "workspace:*",
    "@portfolio/config-eslint": "workspace:*",
    "@portfolio/config-typescript": "workspace:*",
    "@portfolio/vitest-presets": "workspace:*",
    "@tailwindcss/typography": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-standard": "catalog:",
    "tailwindcss": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-react-hooks>eslint": "^10.0.0"
      }
    },
    "overrides": {
      "@conventional-changelog/git-client@<2.0.0": "2.0.0",
      "@csstools/css-calc": "3.1.1",
      "ajv@<6.14.0": "6.12.6",
      "brace-expansion@>=4 <5.0.5": "5.0.5",
      "lodash@>=4.0.0 <=4.17.23": "4.18.0",
      "minimatch@<10.2.1": ">=10.2.1",
      "picomatch@<2.3.2": "2.3.2",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "smol-toml@<1.6.1": "1.6.1",
      "tar@<=7.5.10": "7.5.11",
      "yaml@>=2.0.0 <2.8.3": "2.8.3"
    }
  }
}
