{
  "extends": "@portfolio/config-typescript/src/base.json",
  "compilerOptions": {
    "lib": [
      "ES2020",
      "DOM"
    ],
    "outDir": "./dist",
    "rootDir": "..",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": [
      "node"
    ],
    "paths": {
      "@portfolio/jobs-domain": [
        "../jobs-domain/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
