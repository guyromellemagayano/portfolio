{
  "name": "@portfolio/vitest-presets",
  "version": "1.0.0",
  "private": true,
  "description": "Shared Vitest configuration presets",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./shared/test-setup.ts": {
      "types": "./shared/test-setup.ts",
      "default": "./shared/test-setup.ts"
    }
  },
  "files": [
    "index.ts",
    "browser/**/*.ts",
    "node/**/*.ts",
    "react/**/*.ts",
    "shared/**/*.ts",
    "__mocks__/**/*"
  ],
  "scripts": {
    "build": "node --eval \"\"",
    "check-types": "tsc --noEmit",
    "format": "prettier --write \"{__mocks__,__tests__,browser,node,react,shared}/**/*.{ts,tsx}\" \"*.{ts,tsx,js,cjs,mjs}\"",
    "format:check": "prettier --check \"{__mocks__,__tests__,browser,node,react,shared}/**/*.{ts,tsx}\" \"*.{ts,tsx,js,cjs,mjs}\"",
    "lint": "eslint \"{__mocks__,__tests__,browser,node,react,shared}/**/*.{ts,tsx}\" \"*.{ts,tsx,js,cjs,mjs}\"",
    "lint:fix": "eslint --fix \"{__mocks__,__tests__,browser,node,react,shared}/**/*.{ts,tsx}\" \"*.{ts,tsx,js,cjs,mjs}\"",
    "test": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:coverage:ui": "vitest --coverage --ui",
    "test:run": "vitest run",
    "test:run:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {},
  "devDependencies": {
    "@portfolio/config-eslint": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "jsdom": "catalog:",
    "postcss": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@portfolio/logger": "workspace:*"
  },
  "optionalDependencies": {}
}
