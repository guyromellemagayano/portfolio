{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Astro - TypeScript",
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "preserve",
    "noEmit": true
  },
  "include": [
    ".astro/types.d.ts",
    "src/env.d.ts",
    "**/*.astro",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**"
  ]
}
