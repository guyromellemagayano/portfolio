{
  "name": "@portfolio/config-typescript",
  "version": "1.0.0",
  "private": true,
  "description": "Shared TypeScript configuration",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./astro.json": "./src/astro.json",
    "./base.json": "./src/base.json",
    "./react-app.json": "./src/react-app.json",
    "./react-library.json": "./src/react-library.json",
    "./remix.json": "./src/remix.json",
    "./vite.json": "./src/vite.json"
  },
  "scripts": {
    "build": "node --eval \"\"",
    "format": "prettier --write \"src/**/*.json\"",
    "format:check": "prettier --check \"src/**/*.json\"",
    "lint": "node --eval \"\"",
    "lint:fix": "node --eval \"\""
  },
  "dependencies": {},
  "devDependencies": {
    "astro": "catalog:",
    "prettier": "catalog:"
  },
  "peerDependencies": {},
  "optionalDependencies": {},
