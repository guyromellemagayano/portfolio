# Build Configuration
BUNDLE_ANALYZE="false"
SITE_URL_DEVELOPMENT="http://localhost:4321"
SITE_URL_PREVIEW=""
SITE_URL_PRODUCTION="https://www.guyromellemagayano.com"
WEB_HOST="127.0.0.1"
WEB_PORT="4321"

# Analytics and Monitoring
GOOGLE_ADSENSE_CLIENT_ID=""
GOOGLE_ANALYTICS_MEASUREMENT_ID=""
GOOGLE_TAG_MANAGER_CONTAINER_ID=""
LOGROCKET_APP_ID=""
LOGROCKET_TOKEN=""
NEWRELIC_LICENSE_KEY=""

# Search Verification
BING_SITE_VERIFICATION=""

# Node Environment
NODE_ENV=""

# Azure Configuration
AZURE_INSTRUMENTATION_KEY=""

# Sentry Configuration
SENTRY_AUTH_TOKEN=""
SENTRY_DSN=""
SENTRY_ORG="stack-market-labs"
SENTRY_PROJECT="portfolio-web"
# Leave empty on Vercel to use the deployment commit SHA.
SENTRY_RELEASE=""
SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE="1.0"
SENTRY_REPLAYS_SESSION_SAMPLE_RATE="0.1"
SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING=""
SENTRY_TRACES_SAMPLE_RATE="1.0"

# E2E Testing Configuration
E2E_BASE_URL=""
E2E_CONTENT_ARTICLE_SLUG=""
E2E_CONTENT_PAGE_SLUG=""

# Development Configuration
ENABLE_EXPERIMENTAL_COREPACK="1"

# ESLint Configuration
ESLINT_USE_FLAT_CONFIG="true"
