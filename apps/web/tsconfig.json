{
  "extends": "@portfolio/config-typescript/astro.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "sourceMap": true,
    "outDir": "dist",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "noEmit": true,
    "rootDir": "../..",
    "allowImportingTsExtensions": true,
    "jsx": "preserve",
    "skipDefaultLibCheck": true,
    "ignoreDeprecations": "5.0",
    "paths": {
      "@portfolio/*": [
        "../../packages/*/src/index.ts"
      ],
      "@web/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "src/env.d.ts",
    "**/*.css",
    "**/*.astro",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "../../packages/**/dist/**"
  ]
}
