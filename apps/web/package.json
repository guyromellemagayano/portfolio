{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "check-types": "astro sync && tsc --noEmit",
    "clean": "rimraf node_modules .turbo .astro dist coverage",
    "dev": "astro dev --host ${WEB_HOST:-127.0.0.1} --port ${WEB_PORT:-4321}",
    "format": "prettier --write \"src/**/*.{astro,js,cjs,mjs,ts,cts,mts}\"",
    "format:check": "prettier --check \"src/**/*.{astro,js,cjs,mjs,ts,cts,mts}\"",
    "lint": "eslint \"src/**/*.{astro,js,cjs,mjs,ts,cts,mts}\"",
    "lint:fix": "eslint --fix \"src/**/*.{astro,js,cjs,mjs,ts,cts,mts}\" --max-warnings 0",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\" --allow-empty-input",
    "lint:styles:fix": "stylelint \"src/**/*.{css,scss}\" --fix --allow-empty-input",
    "start": "astro preview --host ${WEB_HOST:-127.0.0.1} --port ${WEB_PORT:-4321}",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:coverage:ui": "vitest --coverage --ui",
    "test:run": "vitest run",
    "test:run:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@astrojs/mdx": "catalog:",
    "@astrojs/react": "catalog:",
    "@astrojs/sitemap": "catalog:",
    "@portfolio/logger": "workspace:*",
    "@portfolio/ui": "workspace:*",
    "@sentry/astro": "catalog:",
    "@vercel/analytics": "catalog:",
    "@vercel/speed-insights": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@astrojs/check": "catalog:",
    "@portfolio/config-eslint": "workspace:*",
    "@portfolio/config-typescript": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "astro": "catalog:",
    "autoprefixer": "catalog:",
    "eslint": "catalog:",
    "postcss": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-astro": "catalog:",
    "remark-gfm": "catalog:",
    "rimraf": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {},
  "optionalDependencies": {}
}
