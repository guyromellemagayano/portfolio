{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "check-types": "astro sync && tsc --noEmit",
    "clean": "rimraf node_modules .turbo .astro dist coverage",
    "dev": "astro dev --host 127.0.0.1 --port 4321",
    "format": "prettier --write \"src/**/*.{astro,js,cjs,mjs,ts,cts,mts,tsx,jsx,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{astro,js,cjs,mjs,ts,cts,mts,tsx,jsx,tsx}\"",
    "lint": "eslint \"src/**/*.{js,cjs,mjs,ts,cts,mts,tsx,jsx,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,cjs,mjs,ts,cts,mts,tsx,jsx,tsx}\" --max-warnings 0",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\" --allow-empty-input",
    "lint:styles:fix": "stylelint \"src/**/*.{css,scss}\" --fix --allow-empty-input",
    "start": "astro preview --host 127.0.0.1 --port 4321",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:coverage:ui": "vitest --coverage --ui",
    "test:run": "vitest run",
    "test:run:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@astrojs/sitemap": "catalog:",
    "@headlessui/react": "catalog:",
    "@portfolio/components": "workspace:*",
    "@portfolio/hooks": "workspace:*",
    "@portfolio/logger": "workspace:*",
    "@portfolio/ui": "workspace:*",
    "@portfolio/utils": "workspace:*",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "fuse.js": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@astrojs/check": "catalog:",
    "@portfolio/config-eslint": "workspace:*",
    "@portfolio/config-typescript": "workspace:*",
    "@portfolio/vitest-presets": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "astro": "catalog:",
    "autoprefixer": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "postcss": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-astro": "catalog:",
    "rimraf": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {},
  "optionalDependencies": {}
}
