---
import PageIntro from "@web/components/PageIntro.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { bookingPaths, services } from "@web/data/services";
import {
  buildPortfolioPageMetadata,
  getPortfolioBrochurePage,
} from "@web/lib/portfolio-brochure";
import {
  appendStructuredData,
  buildBookingStructuredData,
} from "@web/lib/structured-data";

const { page } = await getPortfolioBrochurePage("book");
const metadata = appendStructuredData(
  buildPortfolioPageMetadata(page),
  buildBookingStructuredData(page)
);
---

<BaseLayout metadata={metadata}>
  <PageIntro
    subheading={page.subheading}
    title={page.title}
    intro={page.intro}
  />

  <section
    aria-labelledby="book-paths-heading"
    class="mx-auto max-w-6xl px-6 py-12 sm:px-8"
    role="region"
  >
    <h2
      id="book-paths-heading"
      class="text-3xl font-medium tracking-tight text-zinc-950 sm:text-4xl"
    >
      First conversation options
    </h2>
    <div class="mt-10 grid gap-4 lg:grid-cols-3">
      {
        bookingPaths.map((path) => (
          <article class="rounded-lg border border-zinc-950/10 bg-white p-6">
            <h3 class="text-xl font-medium tracking-tight text-zinc-950">
              {path.title}
            </h3>
            <p class="mt-3 text-sm leading-7 text-zinc-600">
              {path.description}
            </p>
            <a
              href={path.href}
              rel={path.target === "_blank" ? "noopener noreferrer" : undefined}
              target={path.target}
              class="mt-5 inline-flex text-sm font-medium text-zinc-950 underline decoration-zinc-300 underline-offset-4"
            >
              {path.cta}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section
    aria-labelledby="book-services-heading"
    class="mx-auto max-w-6xl border-t border-zinc-950/10 px-6 py-16 sm:px-8"
    role="region"
  >
    <h2
      id="book-services-heading"
      class="text-3xl font-medium tracking-tight text-zinc-950 sm:text-4xl"
    >
      If you already know the shape of the engagement
    </h2>
    <div class="mt-10 space-y-4">
      {
        services.map((service) => (
          <article class="rounded-lg border border-zinc-950/10 bg-white p-6">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h3 class="text-xl font-medium tracking-tight text-zinc-950">
                  {service.title}
                </h3>
                <p class="mt-3 text-sm leading-7 text-zinc-600">
                  {service.bestFor}
                </p>
              </div>
              <a
                href={service.href}
                class="inline-flex text-sm font-medium text-zinc-950 underline decoration-zinc-300 underline-offset-4"
              >
                {service.cta}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
