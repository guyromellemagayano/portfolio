---
/**
 * @file apps/web/src/pages/work.astro
 * @author Guy Romelle Magayano
 * @description Legacy work route that redirects to the selected work section on the about page.
 */

import { toAbsoluteSiteUrl } from "@web/utils/site-url";

const destination = "/about#selected-work";
const canonicalUrl =
  toAbsoluteSiteUrl("/about") ?? "https://www.guyromellemagayano.com/about";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href={canonicalUrl} />
    <title>Selected work moved | Guy Romelle Magayano</title>
  </head>
  <body>
    <a href={destination}>
      Redirecting from <code>/work</code> to <code>{destination}</code>
    </a>
  </body>
</html>
