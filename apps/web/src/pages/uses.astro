---
import PageIntro from "@web/components/PageIntro.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { useCategories } from "@web/data/uses";
import {
  buildPortfolioPageMetadata,
  getPortfolioBrochurePage,
} from "@web/lib-pages/portfolio-brochure";

const { page } = await getPortfolioBrochurePage("uses");
const metadata = buildPortfolioPageMetadata(page);
---

<BaseLayout metadata={metadata}>
  <PageIntro
    subheading={page.subheading}
    title={page.title}
    intro={page.intro}
  />

  <section
    aria-labelledby="uses-categories-heading"
    class="mx-auto max-w-6xl px-6 py-12 sm:px-8"
    role="region"
  >
    <h2
      id="uses-categories-heading"
      class="text-3xl font-medium tracking-tight text-zinc-950 sm:text-4xl"
    >
      Hardware, software, and workflow tools.
    </h2>
    <div class="mt-10 grid gap-4 lg:grid-cols-2">
      {
        useCategories.map((category) => (
          <section
            aria-labelledby={`uses-category-${category.id}`}
            class="rounded-lg border border-zinc-950/10 bg-white p-6"
            role="region"
          >
            <h3
              id={`uses-category-${category.id}`}
              class="text-xl font-medium tracking-tight text-zinc-950"
            >
              {category.title}
            </h3>
            <p class="mt-3 text-sm leading-7 text-zinc-600">{category.intro}</p>
            <div class="mt-6 space-y-4">
              {category.items.map((item) => (
                <article class="border-t border-zinc-950/10 pt-4 first:border-t-0 first:pt-0">
                  <h4 class="text-sm font-semibold text-zinc-950">
                    {item.name}
                  </h4>
                  <p class="mt-2 text-sm leading-6 text-zinc-600">
                    {item.summary}
                  </p>
                  {item.link ? (
                    <a
                      href={item.link.href}
                      rel={item.link.rel}
                      target={item.link.target}
                      class="mt-3 inline-flex text-sm font-medium text-zinc-950 underline decoration-zinc-300 underline-offset-4"
                    >
                      {item.link.label}
                    </a>
                  ) : null}
                </article>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
