---
/**
 * @file apps/web/src/pages/uses.astro
 * @author Guy Romelle Magayano
 * @description Uses page listing tools, gear, and working setup.
 */

import PageIntro from "@web/components/PageIntro.astro";
import SplitSection from "@web/components/SplitSection.astro";
import { useCategories } from "@web/data/uses";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import {
  buildPortfolioPageMetadata,
  getPortfolioBrochurePage,
} from "@web/lib/portfolio-brochure";

const { page } = await getPortfolioBrochurePage("uses");
const metadata = buildPortfolioPageMetadata(page);
---

<BaseLayout metadata={metadata}>
  <PageIntro
    subheading={page.subheading}
    title={page.title}
    intro={page.intro}
  />

  <section
    aria-labelledby="uses-categories-heading"
    class="py-16"
    role="region"
  >
    <h2 id="uses-categories-heading" class="sr-only">
      Hardware, software, and workflow tools
    </h2>
    <div class="space-y-20">
      {
        useCategories.map((category) => (
          <SplitSection
            title={category.title}
            intro={category.intro}
            id={`uses-category-${category.id}`}
          >
            <ul role="list" class="space-y-12">
              {category.items.map((item) => (
                <li class="group relative flex flex-col items-start">
                  <div
                    aria-hidden="true"
                    class="absolute -inset-x-4 -inset-y-6 z-0 scale-95 rounded-lg bg-zinc-50 opacity-0 transition duration-200 group-hover:scale-100 group-hover:opacity-100 sm:-inset-x-6 dark:bg-zinc-800/50"
                  />
                  <h3 class="relative z-10 text-base font-semibold text-zinc-800 dark:text-zinc-100">
                    {item.name}
                  </h3>
                  <p class="relative z-10 mt-2 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
                    {item.summary}
                  </p>
                  {item.link ? (
                    <a
                      href={item.link.href}
                      rel={item.link.rel}
                      target={item.link.target}
                      class="relative z-10 mt-4 inline-flex text-sm font-medium text-teal-600 dark:text-teal-400"
                    >
                      {item.link.label}
                    </a>
                  ) : null}
                </li>
              ))}
            </ul>
          </SplitSection>
        ))
      }
    </div>
  </section>
</BaseLayout>
