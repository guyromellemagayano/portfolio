---
import PageIntro from "@web/components/PageIntro.astro";
import PathwayCards from "@web/components/PathwayCards.astro";
import ServiceCard from "@web/components/ServiceCard.astro";
import SplitSection from "@web/components/SplitSection.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { capabilityClusters, services } from "@web/data/services";
import { pagePathways } from "@web/data/site";
import {
  buildPortfolioPageMetadata,
  getPortfolioBrochurePage,
} from "@web/lib/portfolio-brochure";
import {
  appendStructuredData,
  buildProfessionalServiceStructuredData,
} from "@web/lib/structured-data";

const { page } = await getPortfolioBrochurePage("capabilities");
const metadata = appendStructuredData(
  buildPortfolioPageMetadata(page),
  buildProfessionalServiceStructuredData(page, services)
);
---

<BaseLayout metadata={metadata}>
  <PageIntro
    subheading={page.subheading}
    title={page.title}
    intro={page.intro}
  />

  <section
    aria-labelledby="capabilities-offerings-heading"
    class="mx-auto max-w-2xl px-4 py-16 sm:px-8 lg:max-w-5xl lg:px-12"
    role="region"
  >
    <h2
      id="capabilities-offerings-heading"
      class="max-w-2xl text-2xl font-semibold tracking-tight text-zinc-800 sm:text-3xl dark:text-zinc-100"
    >
      Ways to work together
    </h2>
    <div class="mt-10 grid gap-x-12 gap-y-16 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => <ServiceCard service={service} showPrice />)}
    </div>
  </section>

  <SplitSection
    title="Capability clusters"
    intro="These usually travel with the engagement, even when the first request starts with a narrower surface."
    sectionClass="mt-20"
  >
    <div class="space-y-10">
      {
        capabilityClusters.map((cluster) => (
          <article>
            <h3 class="text-base font-semibold text-zinc-800 dark:text-zinc-100">
              {cluster.title}
            </h3>
            <p class="mt-3 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
              {cluster.items.join(" · ")}
            </p>
          </article>
        ))
      }
    </div>
  </SplitSection>

  <SplitSection
    title="How engagements usually move"
    intro="The work starts by making the actual constraint visible, then narrows into the smallest durable implementation slice."
    sectionClass="mt-20"
  >
    <div class="space-y-10">
      {
        services.map((service) => (
          <article>
            <h3 class="text-base font-semibold text-zinc-800 dark:text-zinc-100">
              {service.title}
            </h3>
            <div class="mt-5 grid gap-6 sm:grid-cols-2">
              <div>
                <h4 class="text-sm font-semibold text-zinc-800 dark:text-zinc-100">
                  Process
                </h4>
                <ul class="mt-3 space-y-2 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
                  {service.process.map((step) => (
                    <li>{step}</li>
                  ))}
                </ul>
              </div>
              <div>
                <h4 class="text-sm font-semibold text-zinc-800 dark:text-zinc-100">
                  Outcome
                </h4>
                <ul class="mt-3 space-y-2 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
                  {service.outcomes.map((outcome) => (
                    <li>{outcome}</li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </SplitSection>

  <PathwayCards
    eyebrow="Next"
    id="services-next-steps-heading"
    title="Validate the service path before reaching out."
    intro="Proof, writing, and direct context each answer a different part of the fit question."
    pathways={pagePathways.capabilities}
    sectionClass="mt-20 pb-24"
  />
</BaseLayout>
