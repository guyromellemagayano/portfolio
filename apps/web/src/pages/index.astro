---
import ArticleCard from "@web/components/ArticleCard.astro";
import ProjectCard from "@web/components/ProjectCard.astro";
import ServiceCard from "@web/components/ServiceCard.astro";
import { PHOTO_GALLERY_PHOTOS } from "@web/config/photo-gallery";
import { workExperience } from "@web/data/clients";
import { labProjects, workProjects } from "@web/data/projects";
import { services } from "@web/data/services";
import { foundationCapabilities, profile, socialLinks } from "@web/data/site";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import {
  buildPortfolioPageMetadata,
  getPortfolioBrochurePage,
} from "@web/lib/portfolio-brochure";
import {
  appendStructuredData,
  buildPersonStructuredData,
  buildProfessionalServiceStructuredData,
  buildWebsiteStructuredData,
} from "@web/lib/structured-data";
import { getAllArticles } from "@web/utils/articles";

const { page } = await getPortfolioBrochurePage("");
const metadata = appendStructuredData(
  buildPortfolioPageMetadata(page),
  buildWebsiteStructuredData(),
  buildPersonStructuredData(),
  buildProfessionalServiceStructuredData(page, services)
);
const articles = await getAllArticles();
const featuredServices = services.filter((service) => service.featured);
const featuredWork = workProjects.filter((project) => project.featured);
const featuredArticles = articles.slice(0, 3);
const featuredLabs = labProjects
  .filter((project) => project.featured)
  .slice(0, 2);
const recentRoles = workExperience.slice(0, 4);

const formatRoleDate = (value?: string) =>
  value
    ? new Intl.DateTimeFormat("en-US", { year: "numeric" }).format(
        new Date(value)
      )
    : "Present";
---

<BaseLayout metadata={metadata}>
  <section
    aria-labelledby="home-hero-heading"
    class="mx-auto max-w-2xl px-4 pt-16 sm:px-8 sm:pt-32 lg:max-w-5xl lg:px-12"
    role="region"
  >
    <div class="max-w-2xl">
      <p
        class="text-xs font-semibold tracking-[0.28em] text-zinc-500 uppercase dark:text-zinc-400"
      >
        {page.subheading}
      </p>
      <h1
        id="home-hero-heading"
        class="mt-4 text-4xl font-bold tracking-tight text-zinc-800 sm:text-5xl dark:text-zinc-100"
      >
        {profile.heroTitle}
      </h1>
      <p class="mt-6 text-base leading-8 text-zinc-600 dark:text-zinc-300">
        {profile.heroIntro}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/work"
          class="inline-flex items-center justify-center rounded-full bg-zinc-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-zinc-700"
          data-analytics-content-id="/work"
          data-analytics-content-name="View selected work"
          data-analytics-content-type="call_to_action"
          data-analytics-placement="home-hero-primary"
        >
          View selected work
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-full border border-zinc-200 bg-white px-5 py-3 text-sm font-medium text-zinc-800 transition hover:border-zinc-300 dark:border-zinc-700/60 dark:bg-zinc-900 dark:text-zinc-100 dark:hover:border-zinc-600"
          data-analytics-content-id="/contact"
          data-analytics-content-name="Start a conversation"
          data-analytics-content-type="call_to_action"
          data-analytics-placement="home-hero-secondary"
        >
          Start a conversation
        </a>
      </div>
      <ul
        class="mt-10 flex flex-wrap gap-x-6 gap-y-3 text-sm text-zinc-600 dark:text-zinc-300"
        role="list"
      >
        {
          socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                rel={
                  link.href.startsWith("http")
                    ? "noopener noreferrer"
                    : undefined
                }
                target={link.href.startsWith("http") ? "_blank" : undefined}
                class="transition hover:text-teal-600 dark:hover:text-teal-400"
                data-analytics-content-id={link.id}
                data-analytics-content-name={link.label}
                data-analytics-content-type="social_link"
                data-analytics-placement="home-social"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="mt-16 sm:mt-20" aria-label="Portfolio photo gallery">
    <div class="-my-4 flex justify-center gap-5 overflow-hidden py-4 sm:gap-8">
      {
        PHOTO_GALLERY_PHOTOS.map((photo, index) => (
          <div
            class:list={[
              "relative aspect-[9/10] w-44 flex-none overflow-hidden rounded-xl bg-zinc-100 sm:w-72 sm:rounded-2xl",
              "dark:bg-zinc-800",
              index % 5 === 0 || index % 5 === 2 || index % 5 === 3
                ? "rotate-2"
                : "-rotate-2",
            ]}
          >
            <img
              src={typeof photo === "string" ? photo : photo.src}
              alt=""
              class="absolute inset-0 h-full w-full object-cover"
              aria-hidden="true"
              loading={index === 0 ? "eager" : "lazy"}
            />
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto mt-24 max-w-2xl px-4 sm:px-8 lg:max-w-5xl lg:px-12">
    <div class="grid grid-cols-1 gap-16 lg:grid-cols-[minmax(0,1fr)_20rem]">
      <div class="space-y-20">
        <section aria-labelledby="home-work-heading">
          <div class="max-w-2xl">
            <p
              class="text-xs font-semibold tracking-[0.28em] text-zinc-500 uppercase dark:text-zinc-400"
            >
              Selected work
            </p>
            <h2
              id="home-work-heading"
              class="mt-3 text-2xl font-semibold tracking-tight text-zinc-800 sm:text-3xl dark:text-zinc-100"
            >
              Production systems shaped around maintainability, delivery risk,
              and product quality.
            </h2>
          </div>
          <div class="mt-10 grid gap-x-12 gap-y-16 sm:grid-cols-2">
            {featuredWork.map((project) => <ProjectCard project={project} />)}
          </div>
        </section>

        <section aria-labelledby="home-notes-heading">
          <div class="max-w-2xl">
            <p
              class="text-xs font-semibold tracking-[0.28em] text-zinc-500 uppercase dark:text-zinc-400"
            >
              Notes
            </p>
            <h2
              id="home-notes-heading"
              class="mt-3 text-2xl font-semibold tracking-tight text-zinc-800 sm:text-3xl dark:text-zinc-100"
            >
              Writing on architecture, delivery systems, and calmer product
              engineering.
            </h2>
          </div>
          <div class="mt-10 flex max-w-3xl flex-col space-y-16">
            {
              featuredArticles.map((article) => (
                <ArticleCard article={article} />
              ))
            }
          </div>
        </section>

        <section aria-labelledby="home-services-heading">
          <div class="max-w-2xl">
            <p
              class="text-xs font-semibold tracking-[0.28em] text-zinc-500 uppercase dark:text-zinc-400"
            >
              Capabilities
            </p>
            <h2
              id="home-services-heading"
              class="mt-3 text-2xl font-semibold tracking-tight text-zinc-800 sm:text-3xl dark:text-zinc-100"
            >
              Engagement paths for teams that need sharper architecture and
              hands-on delivery.
            </h2>
          </div>
          <div class="mt-10 grid gap-x-12 gap-y-16 sm:grid-cols-2">
            {
              featuredServices.map((service) => (
                <ServiceCard service={service} showPrice />
              ))
            }
          </div>
        </section>

        <section aria-labelledby="home-labs-heading">
          <div class="max-w-2xl">
            <p
              class="text-xs font-semibold tracking-[0.28em] text-zinc-500 uppercase dark:text-zinc-400"
            >
              Labs
            </p>
            <h2
              id="home-labs-heading"
              class="mt-3 text-2xl font-semibold tracking-tight text-zinc-800 sm:text-3xl dark:text-zinc-100"
            >
              Internal product experiments that keep the production work honest.
            </h2>
          </div>
          <div class="mt-10 grid gap-x-12 gap-y-16 sm:grid-cols-2">
            {
              featuredLabs.map((project) => (
                <ProjectCard project={project} compact idPrefix="home-labs" />
              ))
            }
          </div>
        </section>
      </div>

      <aside class="space-y-8">
        <section
          class="rounded-2xl border border-zinc-100 p-6 dark:border-zinc-800"
        >
          <h2
            class="flex text-sm font-semibold text-zinc-900 dark:text-zinc-100"
          >
            <span
              class="mr-3 inline-flex h-6 w-6 items-center justify-center rounded-full bg-zinc-900 text-[0.625rem] font-semibold text-white dark:bg-zinc-100 dark:text-zinc-950"
            >
              GM
            </span>
            Recent roles
          </h2>
          <ol class="mt-6 space-y-4">
            {
              recentRoles.map((role) => (
                <li class="flex gap-4">
                  <div
                    aria-hidden="true"
                    class="relative mt-1 flex h-10 w-10 flex-none items-center justify-center rounded-full bg-zinc-900 text-[0.625rem] font-semibold tracking-[0.08em] text-white shadow-md ring-1 ring-zinc-900/5 dark:bg-zinc-100 dark:text-zinc-950 dark:ring-white/10"
                  >
                    {role.company
                      .split(/\s+/)
                      .slice(0, 2)
                      .map((word) => word[0])
                      .join("")
                      .toUpperCase()}
                  </div>
                  <dl class="flex flex-auto flex-wrap gap-x-2">
                    <dt class="sr-only">Company</dt>
                    <dd class="w-full flex-none text-sm font-medium text-zinc-900 dark:text-zinc-100">
                      {role.company}
                    </dd>
                    <dt class="sr-only">Role</dt>
                    <dd class="text-xs text-zinc-500 dark:text-zinc-400">
                      {role.role}
                    </dd>
                    <dt class="sr-only">Dates</dt>
                    <dd class="ml-auto text-xs text-zinc-400 dark:text-zinc-500">
                      <time datetime={role.startDate}>
                        {formatRoleDate(role.startDate)}
                      </time>{" "}
                      <span aria-hidden="true">—</span>{" "}
                      <time datetime={role.endDate || role.startDate}>
                        {role.current
                          ? "Present"
                          : formatRoleDate(role.endDate)}
                      </time>
                    </dd>
                  </dl>
                </li>
              ))
            }
          </ol>
          <a
            href="/about"
            class="mt-6 inline-flex items-center text-sm font-medium text-teal-600 dark:text-teal-400"
          >
            More about me
          </a>
        </section>

        <section
          class="rounded-2xl border border-zinc-100 p-6 dark:border-zinc-800"
        >
          <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">
            What I optimize for
          </h2>
          <ul
            class="mt-4 space-y-3 text-sm leading-7 text-zinc-600 dark:text-zinc-300"
          >
            {foundationCapabilities.map((capability) => <li>{capability}</li>)}
          </ul>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
