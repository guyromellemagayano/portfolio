---
import PageIntro from "@web/components/PageIntro.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { certifications } from "@web/data/certifications";
import { workExperience } from "@web/data/clients";
import { focusAreas, operatingPrinciples, profile } from "@web/data/site";
import {
  buildPortfolioPageMetadata,
  getPortfolioBrochurePage,
} from "@web/lib/portfolio-brochure";

const { page } = await getPortfolioBrochurePage("about");
const metadata = buildPortfolioPageMetadata(page);
const formatRoleDate = (value?: string) =>
  value
    ? new Intl.DateTimeFormat("en-US", { year: "numeric" }).format(
        new Date(value)
      )
    : "Present";
---

<BaseLayout metadata={metadata}>
  <PageIntro
    subheading={page.subheading}
    title={page.title}
    intro={profile.heroIntro}
  />

  <section
    aria-labelledby="about-summary-heading"
    class="mx-auto grid max-w-6xl gap-4 px-6 pt-12 sm:px-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]"
    role="region"
  >
    <div class="rounded-lg border border-zinc-950/10 bg-white p-6">
      <h2
        id="about-summary-heading"
        class="text-xl font-medium tracking-tight text-zinc-950"
      >
        {profile.name}
      </h2>
      <p class="mt-3 text-sm leading-7 text-zinc-600">{profile.role}</p>
      <p class="mt-5 text-sm leading-7 text-zinc-600">
        I work across frontend architecture, platform foundations, content
        modeling, and delivery systems. The common thread is making the product
        easier to extend without creating a maze of exceptions.
      </p>
    </div>

    <div class="rounded-lg border border-zinc-950/10 bg-white p-6">
      <h2 class="text-sm font-semibold text-zinc-950">Focus areas</h2>
      <div class="mt-4 flex flex-wrap gap-2" role="list">
        {
          focusAreas.map((area) => (
            <span
              class="rounded-full border border-zinc-950/10 px-3 py-2 text-sm text-zinc-700"
              role="listitem"
            >
              {area}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <section
    aria-labelledby="about-experience-heading"
    class="mx-auto max-w-6xl border-t border-zinc-950/10 px-6 py-16 sm:px-8"
    role="region"
  >
    <h2
      id="about-experience-heading"
      class="text-3xl font-medium tracking-tight text-zinc-950 sm:text-4xl"
    >
      Experience timeline
    </h2>
    <div class="mt-10 space-y-4">
      {
        workExperience.map((entry) => (
          <article class="rounded-lg border border-zinc-950/10 bg-white p-6">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h3 class="text-xl font-medium tracking-tight text-zinc-950">
                  {entry.role}
                </h3>
                <p class="mt-1 text-sm text-zinc-600">{entry.company}</p>
              </div>
              <p class="text-sm text-zinc-500">
                {formatRoleDate(entry.startDate)} -{" "}
                {entry.current ? "Present" : formatRoleDate(entry.endDate)}
              </p>
            </div>
            <p class="mt-4 text-sm leading-7 text-zinc-600">{entry.summary}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section
    aria-labelledby="about-certifications-heading"
    class="mx-auto max-w-6xl border-t border-zinc-950/10 px-6 py-16 sm:px-8"
    role="region"
  >
    <h2
      id="about-certifications-heading"
      class="text-3xl font-medium tracking-tight text-zinc-950 sm:text-4xl"
    >
      Certifications
    </h2>
    <div class="mt-10 grid gap-4 lg:grid-cols-3">
      {
        certifications.map((certification) => (
          <article class="rounded-lg border border-zinc-950/10 bg-white p-6">
            <p class="text-xs font-semibold tracking-[0.24em] text-zinc-500 uppercase">
              {certification.category}
            </p>
            <h3 class="mt-3 text-lg font-medium tracking-tight text-zinc-950">
              {certification.name}
            </h3>
            <p class="mt-3 text-sm leading-7 text-zinc-600">
              {certification.earned ? "Earned proof point" : "In progress"}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section
    aria-labelledby="about-principles-heading"
    class="mx-auto max-w-6xl border-t border-zinc-950/10 px-6 py-16 sm:px-8"
    role="region"
  >
    <div class="grid gap-4 lg:grid-cols-2">
      <h2
        id="about-principles-heading"
        class="text-3xl font-medium tracking-tight text-zinc-950 sm:text-4xl"
      >
        The working rules behind the portfolio.
      </h2>
      <div class="space-y-4">
        {
          operatingPrinciples.map((principle) => (
            <div class="rounded-lg border border-zinc-950/10 bg-white p-5 text-sm leading-7 text-zinc-600">
              {principle}
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
