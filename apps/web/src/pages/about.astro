---
/**
 * @file apps/web/src/pages/about.astro
 * @author Guy Romelle Magayano
 * @description About page covering profile, selected work, experience, and working principles.
 */

import Eyebrow from "@web/components/Eyebrow.astro";
import Heading from "@web/components/Heading.astro";
import HeroTwoColumnWithPhoto from "@web/components/HeroTwoColumnWithPhoto.astro";
import PathwayCards from "@web/components/PathwayCards.astro";
import ProjectCard from "@web/components/ProjectCard.astro";
import SplitSection from "@web/components/SplitSection.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { certifications } from "@web/data/certifications";
import { workExperience } from "@web/data/clients";
import { getProjectPath, workProjects } from "@web/data/projects";
import {
  focusAreas,
  operatingPrinciples,
  pagePathways,
  profile,
  socialLinks,
} from "@web/data/site";
import portraitImage from "@web/images/portrait.jpg";
import {
  buildPortfolioPageMetadata,
  getPortfolioBrochurePage,
} from "@web/lib/portfolio-brochure";
import {
  appendStructuredData,
  buildCollectionPageStructuredData,
} from "@web/lib/structured-data";

const { page } = await getPortfolioBrochurePage("about");
const metadata = appendStructuredData(
  buildPortfolioPageMetadata(page),
  buildCollectionPageStructuredData(page, workProjects, getProjectPath)
);
const formatRoleDate = (value?: string) =>
  value
    ? new Intl.DateTimeFormat("en-US", { year: "numeric" }).format(
        new Date(value)
      )
    : "Present";
---

<BaseLayout metadata={metadata}>
  <HeroTwoColumnWithPhoto
    aria-labelledby="about-hero-heading"
    class="pt-16 sm:pt-32"
    role="region"
    subheadlineClass="max-w-2xl space-y-7 text-base/8 text-zinc-600 dark:text-zinc-300"
  >
    <Eyebrow slot="eyebrow" as="p">
      {page.subheading}
    </Eyebrow>
    <Heading slot="headline" id="about-hero-heading" class="max-w-4xl">
      {page.title}
    </Heading>
    <div slot="subheadline">
      <p>{profile.heroIntro}</p>
      <p>
        I work across frontend architecture, platform foundations, content
        modeling, and delivery systems. The throughline is clarity: make the
        system easier to extend, easier to reason about, and less expensive to
        change under pressure.
      </p>
      <p>
        Most of my work sits where delivery slows down: route structures that
        drift, content systems that stop fitting the product, release paths that
        feel unsafe, or shared abstractions that are now hiding more than they
        help.
      </p>
    </div>
    <img
      slot="photo"
      src={portraitImage.src}
      alt={`${profile.name} portrait`}
      width={portraitImage.width}
      height={portraitImage.height}
      class="aspect-square w-full bg-zinc-100 object-cover dark:bg-zinc-800"
    />
    <ul slot="aside" role="list" class="space-y-4">
      {
        socialLinks.map((link) => (
          <li class="flex">
            <a
              href={link.href}
              rel={
                link.href.startsWith("http") ? "noopener noreferrer" : undefined
              }
              target={link.href.startsWith("http") ? "_blank" : undefined}
              class="group flex text-sm font-medium text-zinc-800 transition hover:text-teal-600 dark:text-zinc-100 dark:hover:text-teal-400"
            >
              <span>{link.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </HeroTwoColumnWithPhoto>

  <SplitSection
    title="Focus areas"
    sectionClass="mt-24"
    intro="The themes that show up most often in my consulting and implementation work."
  >
    <div class="flex flex-wrap gap-3">
      {
        focusAreas.map((area) => (
          <span class="rounded-full border border-zinc-200 px-3 py-2 text-sm text-zinc-700 dark:border-zinc-700/60 dark:text-zinc-300">
            {area}
          </span>
        ))
      }
    </div>
  </SplitSection>

  <SplitSection
    id="selected-work"
    title="Selected work"
    sectionClass="mt-20 scroll-mt-32"
    intro="Production case studies across commerce, publishing, SaaS, and operational systems that show how I work in real delivery environments."
    contentClass="grid gap-x-12 gap-y-16 sm:grid-cols-2"
  >
    {workProjects.map((project) => <ProjectCard project={project} />)}
  </SplitSection>

  <SplitSection
    title="Experience timeline"
    sectionClass="mt-20"
    intro="Recent roles that shaped the platform, publishing, and commerce work shown across the site."
  >
    <div class="space-y-8">
      {
        workExperience.map((entry) => (
          <article>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-baseline sm:justify-between">
              <div>
                <h3 class="text-base font-semibold text-zinc-800 dark:text-zinc-100">
                  {entry.role}
                </h3>
                <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
                  {entry.company}
                </p>
              </div>
              <p class="text-sm text-zinc-400 dark:text-zinc-500">
                {formatRoleDate(entry.startDate)} -{" "}
                {entry.current ? "Present" : formatRoleDate(entry.endDate)}
              </p>
            </div>
            <p class="mt-3 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
              {entry.summary}
            </p>
          </article>
        ))
      }
    </div>
  </SplitSection>

  <SplitSection
    title="Certifications"
    sectionClass="mt-20"
    intro="A mix of earned credentials and current upskilling tracks that support the work."
  >
    <div class="grid gap-8 sm:grid-cols-2">
      {
        certifications.map((certification) => (
          <article class="group relative flex flex-col items-start">
            <div
              aria-hidden="true"
              class="absolute -inset-x-4 -inset-y-6 z-0 scale-95 rounded-2xl bg-zinc-50 opacity-0 transition duration-200 group-hover:scale-100 group-hover:opacity-100 sm:-inset-x-6 dark:bg-zinc-800/50"
            />
            <p class="relative z-10 text-xs font-semibold tracking-[0.24em] text-zinc-500 uppercase dark:text-zinc-400">
              {certification.category}
            </p>
            <h3 class="relative z-10 mt-4 text-base font-semibold text-zinc-800 dark:text-zinc-100">
              {certification.name}
            </h3>
            <p class="relative z-10 mt-2 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
              {certification.earned ? "Earned proof point" : "In progress"}
            </p>
          </article>
        ))
      }
    </div>
  </SplitSection>

  <SplitSection
    title="Working principles"
    sectionClass="mt-20"
    intro="The rules that matter most once a codebase or team starts to grow."
  >
    <div class="space-y-4">
      {
        operatingPrinciples.map((principle) => (
          <p class="text-sm leading-7 text-zinc-600 dark:text-zinc-300">
            {principle}
          </p>
        ))
      }
    </div>
  </SplitSection>

  <PathwayCards
    eyebrow="Next"
    id="about-next-steps-heading"
    title="Move from background to evidence."
    intro="The next useful signal is either proof of past work, a service shape, or direct context for a conversation."
    pathways={pagePathways.about}
    sectionClass="mt-20 pb-24"
  />
</BaseLayout>
