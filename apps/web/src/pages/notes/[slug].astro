---
/**
 * @file apps/web/src/pages/notes/[slug].astro
 * @author Guy Romelle Magayano
 * @description Note detail page for an individual article.
 */

import Container from "@web/components/Container.astro";
import RichText from "@web/components/RichText.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { formatDate } from "@web/lib/format-date";
import {
  buildPageMetadata,
  buildOpenGraphImages,
  buildTwitterImages,
  clampMetadataDescription,
  DEFAULT_SOCIAL_IMAGE_HEIGHT,
  DEFAULT_SOCIAL_IMAGE_PATH,
  DEFAULT_SOCIAL_IMAGE_WIDTH,
  resolveMetadataDescription,
  resolveMetadataTitle,
} from "@web/lib/metadata";
import { type WebPageMetadata } from "@web/lib/metadata.types";
import {
  buildArticleStructuredData,
  buildBreadcrumbListStructuredData,
} from "@web/lib/structured-data";
import {
  getAllArticles,
  getArticleBySlug,
  type ArticleDetail,
} from "@web/utils/articles";

export async function getStaticPaths() {
  const articles = await getAllArticles();

  return articles.map((article) => ({
    params: {
      slug: article.slug,
    },
  }));
}

const slug = Astro.params.slug ?? "";
const article = await getArticleBySlug(slug);

if (!article) {
  return Astro.redirect("/404", 404);
}

function getNotePath(articleRecord: ArticleDetail): string {
  return articleRecord.seoCanonicalPath || `/notes/${articleRecord.slug}`;
}

function buildArticleMetadata(articleRecord: ArticleDetail): WebPageMetadata {
  const description = clampMetadataDescription(
    resolveMetadataDescription(
      articleRecord.seoDescription,
      articleRecord.description || articleRecord.title
    )
  );
  const notePath = getNotePath(articleRecord);
  const socialImagePath =
    articleRecord.seoOgImage ||
    articleRecord.image ||
    DEFAULT_SOCIAL_IMAGE_PATH;
  const socialImageAlt =
    articleRecord.seoOgImageAlt ||
    articleRecord.imageAlt ||
    articleRecord.title;

  return buildPageMetadata({
    canonicalPathOrUrl: notePath,
    description,
    openGraphImages: buildOpenGraphImages({
      alt: socialImageAlt,
      height:
        articleRecord.seoOgImageHeight ||
        articleRecord.imageHeight ||
        DEFAULT_SOCIAL_IMAGE_HEIGHT,
      pathOrUrl: socialImagePath,
      width:
        articleRecord.seoOgImageWidth ||
        articleRecord.imageWidth ||
        DEFAULT_SOCIAL_IMAGE_WIDTH,
    }),
    openGraphPublishedTime: articleRecord.date,
    openGraphType: "article",
    robots: {
      index: articleRecord.seoNoIndex === true ? false : true,
      follow: articleRecord.seoNoFollow === true ? false : true,
    },
    structuredData: [
      buildArticleStructuredData(articleRecord),
      buildBreadcrumbListStructuredData([
        { name: "Home", path: "/" },
        { name: "Notes", path: "/notes" },
        {
          name: articleRecord.title,
          path: notePath,
        },
      ]),
    ],
    title: resolveMetadataTitle(articleRecord.seoTitle, articleRecord.title),
    twitterCard: articleRecord.seoTwitterCard,
    twitterImages: buildTwitterImages({ pathOrUrl: socialImagePath }),
  });
}

const metadata = buildArticleMetadata(article);
const formattedDate = formatDate(article.date);
---

<BaseLayout metadata={metadata}>
  <article>
    <Container class="pt-16 sm:pt-32">
      <div class="max-w-3xl">
        <a
          href="/notes"
          class="text-sm font-medium text-zinc-500 transition hover:text-teal-600 dark:text-zinc-400 dark:hover:text-teal-400"
        >
          Back to notes
        </a>
        <header class="mt-8 flex flex-col">
          <time
            class="order-first flex items-center text-base text-zinc-400 dark:text-zinc-500"
            datetime={article.date}
          >
            <span
              class="h-4 w-0.5 rounded-full bg-zinc-200 dark:bg-zinc-700"
              aria-hidden="true"></span>
            <span class="ml-3">{formattedDate}</span>
          </time>
          <h1
            class="mt-6 text-4xl font-bold tracking-tight text-zinc-800 sm:text-5xl dark:text-zinc-100"
          >
            {article.title}
          </h1>
          <p class="mt-6 text-base leading-8 text-zinc-600 dark:text-zinc-300">
            {article.description}
          </p>
        </header>

        {
          article.image ? (
            <figure class="my-8 overflow-hidden rounded-2xl border border-zinc-200/60 bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-900">
              <img
                src={article.image}
                alt={article.imageAlt || article.title}
                class="h-auto w-full object-cover"
                width={article.imageWidth || 1600}
                height={article.imageHeight || 900}
                loading="lazy"
              />
            </figure>
          ) : null
        }

        <div class="prose-zinc prose mt-10 max-w-none dark:prose-invert">
          <RichText value={article.body} fallbackImageAlt={article.title} />
        </div>
      </div>
    </Container>
  </article>
</BaseLayout>
