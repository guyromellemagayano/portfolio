---
import ArticleCard from "@web/components/ArticleCard.astro";
import Container from "@web/components/Container.astro";
import PageIntro from "@web/components/PageIntro.astro";
import PathwayCards from "@web/components/PathwayCards.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { pagePathways } from "@web/data/site";
import {
  buildPortfolioPageMetadata,
  getPortfolioBrochurePage,
} from "@web/lib/portfolio-brochure";
import {
  appendStructuredData,
  buildCollectionPageStructuredData,
} from "@web/lib/structured-data";
import { getAllArticles } from "@web/utils/articles";

const { page } = await getPortfolioBrochurePage("notes");
const articles = await getAllArticles();
const metadata = appendStructuredData(
  buildPortfolioPageMetadata(page),
  buildCollectionPageStructuredData(
    page,
    articles,
    (article) => `/notes/${article.slug}`
  )
);
---

<BaseLayout metadata={metadata}>
  <PageIntro
    subheading={page.subheading}
    title={page.title}
    intro={page.intro}
  />

  <section aria-labelledby="notes-list-heading" role="region">
    <Container class="py-16">
      <h2 id="notes-list-heading" class="sr-only">Note list</h2>
      <div
        class="md:border-l md:border-zinc-100 md:pl-6 md:dark:border-zinc-700/40"
      >
        <div class="flex max-w-3xl flex-col space-y-16">
          {articles.map((article) => <ArticleCard article={article} />)}
        </div>
      </div>
    </Container>
  </section>

  <PathwayCards
    eyebrow="Next"
    id="notes-next-steps-heading"
    title="Move from ideas to evidence or action."
    intro="The notes explain judgment; the next signal is either service fit, production proof, or a specific constraint."
    pathways={pagePathways.notes}
    sectionClass="pb-24"
  />
</BaseLayout>
