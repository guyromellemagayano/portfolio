---
/**
 * @file apps/web/src/pages/[slug].astro
 * @author Guy Romelle Magayano
 * @description Standalone content page for brochure-style site sections.
 */

import Container from "@web/components/Container.astro";
import PageIntro from "@web/components/PageIntro.astro";
import RichText from "@web/components/RichText.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { type WebPageMetadata } from "@web/lib/metadata.types";
import {
  buildPageMetadata,
  buildOpenGraphImages,
  clampMetadataDescription,
  buildTwitterImages,
  resolveMetadataDescription,
  resolveMetadataTitle,
} from "@web/lib/metadata";
import {
  buildBreadcrumbListStructuredData,
  buildStandalonePageStructuredData,
} from "@web/lib/structured-data";
import {
  getAllPages,
  getPageBySlug,
  type StandalonePageDetail,
} from "@web/utils/pages";

export async function getStaticPaths() {
  const staticRouteSlugs = new Set([
    "about",
    "capabilities",
    "contact",
    "labs",
    "notes",
    "transparency",
    "uses",
    "work",
  ]);
  const pages = await getAllPages();

  return pages
    .filter((page) => !staticRouteSlugs.has(page.slug))
    .map((page) => ({
      params: {
        slug: page.slug,
      },
    }));
}

const slug = Astro.params.slug ?? "";
const page = await getPageBySlug(slug);

if (!page) {
  return Astro.redirect("/404", 404);
}

function buildStandalonePageMetadata(
  pageRecord: StandalonePageDetail
): WebPageMetadata {
  const description = clampMetadataDescription(
    resolveMetadataDescription(
      pageRecord.seoDescription,
      pageRecord.intro,
      pageRecord.title
    )
  );
  const canonicalPath = pageRecord.seoCanonicalPath || `/${pageRecord.slug}`;

  return buildPageMetadata({
    canonicalPathOrUrl: canonicalPath,
    description,
    openGraphImages: buildOpenGraphImages(),
    robots: {
      index: pageRecord.seoNoIndex === true ? false : true,
      follow: pageRecord.seoNoFollow === true ? false : true,
    },
    structuredData: [
      buildStandalonePageStructuredData(pageRecord),
      buildBreadcrumbListStructuredData([
        { name: "Home", path: "/" },
        {
          name: pageRecord.subheading || pageRecord.title,
          path: canonicalPath,
        },
      ]),
    ],
    title: resolveMetadataTitle(pageRecord.seoTitle, pageRecord.title),
    twitterCard: pageRecord.seoTwitterCard,
    twitterImages: buildTwitterImages(),
  });
}

const metadata = buildStandalonePageMetadata(page);
---

<BaseLayout metadata={metadata}>
  <PageIntro
    subheading={page.subheading}
    title={page.title}
    intro={page.intro}
  />
  {
    page.body.length > 0 ? (
      <section aria-label={`${page.title} content`}>
        <Container class="py-16">
          <div class="prose max-w-3xl prose-zinc dark:prose-invert">
            <RichText value={page.body} fallbackImageAlt={page.title} />
          </div>
        </Container>
      </section>
    ) : null
  }
</BaseLayout>
