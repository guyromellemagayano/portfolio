---
import CTA from "@web/components/CTA.astro";
import PageIntro from "@web/components/PageIntro.astro";
import ServiceCard from "@web/components/ServiceCard.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { capabilityClusters, services } from "@web/data/services";
import {
  buildPortfolioPageMetadata,
  getPortfolioBrochurePage,
} from "@web/lib-pages/portfolio-brochure";
import {
  appendStructuredData,
  buildProfessionalServiceStructuredData,
} from "@web/lib-pages/structured-data";

const { page } = await getPortfolioBrochurePage("services");
const metadata = appendStructuredData(
  buildPortfolioPageMetadata(page),
  buildProfessionalServiceStructuredData(page, services)
);
---

<BaseLayout metadata={metadata}>
  <PageIntro
    subheading={page.subheading}
    title={page.title}
    intro={page.intro}
  />

  <section
    aria-labelledby="services-offerings-heading"
    class="mx-auto max-w-6xl px-6 py-12 sm:px-8"
    role="region"
  >
    <h2
      id="services-offerings-heading"
      class="text-3xl font-medium tracking-tight text-zinc-950 sm:text-4xl"
    >
      Ways to work together
    </h2>
    <div class="mt-10 grid gap-4 lg:grid-cols-3">
      {services.map((service) => <ServiceCard service={service} showPrice />)}
    </div>
  </section>

  <section
    aria-labelledby="services-capabilities-heading"
    class="mx-auto max-w-6xl border-t border-zinc-950/10 px-6 py-16 sm:px-8"
    role="region"
  >
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
      <h2
        id="services-capabilities-heading"
        class="text-3xl font-medium tracking-tight text-zinc-950 sm:text-4xl"
      >
        Capability clusters that usually come with the work.
      </h2>
      <div class="space-y-4">
        {
          capabilityClusters.map((cluster) => (
            <article class="rounded-lg border border-zinc-950/10 bg-white p-6">
              <h3 class="text-lg font-medium text-zinc-950">{cluster.title}</h3>
              <p class="mt-3 text-sm leading-7 text-zinc-600">
                {cluster.items.join(" · ")}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTA
    title="Not sure which engagement shape fits yet?"
    body="Start with the current bottleneck, the product surface that is getting hard to extend, and whether you need review, guidance, or hands-on execution."
    primaryHref="/book"
    primaryLabel="Choose a starting path"
    secondaryHref="/hire"
    secondaryLabel="Go straight to the hire page"
  />
</BaseLayout>
