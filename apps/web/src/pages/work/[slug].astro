---
import CTA from "@web/components/CTA.astro";
import SplitSection from "@web/components/SplitSection.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { getProjectPath, type Project, workProjects } from "@web/data/projects";
import {
  buildOpenGraphImages,
  buildTwitterImages,
  DEFAULT_TWITTER_CARD,
  resolveMetadataTitle,
  SITE_NAME,
} from "@web/lib/metadata";
import { type WebPageMetadata } from "@web/lib/metadata.types";
import {
  buildBreadcrumbListStructuredData,
  buildProjectStructuredData,
} from "@web/lib/structured-data";
import { toAbsoluteSiteUrl } from "@web/utils/site-url";

export function getStaticPaths() {
  return workProjects.map((project) => ({
    params: {
      slug: project.slug,
    },
  }));
}

const slug = Astro.params.slug ?? "";
const project = workProjects.find((entry) => entry.slug === slug);

if (!project) {
  return Astro.redirect("/404", 404);
}

function buildProjectMetadata(projectRecord: Project): WebPageMetadata {
  const projectPath = getProjectPath(projectRecord);
  const canonicalUrl = toAbsoluteSiteUrl(projectPath);
  const title = `${projectRecord.title} Case Study`;
  const description = projectRecord.caseStudy.outcome;

  return {
    title: resolveMetadataTitle(title, projectRecord.title),
    description,
    alternates: {
      canonical: canonicalUrl,
    },
    robots: {
      index: true,
      follow: true,
    },
    openGraph: {
      type: "website",
      title,
      description,
      url: canonicalUrl,
      siteName: SITE_NAME,
      images: buildOpenGraphImages({
        alt: `${projectRecord.title} case study by Guy Romelle Magayano`,
      }),
    },
    twitter: {
      card: DEFAULT_TWITTER_CARD,
      title,
      description,
      images: buildTwitterImages(),
    },
    structuredData: [
      buildProjectStructuredData(projectRecord),
      buildBreadcrumbListStructuredData([
        { name: "Home", path: "/" },
        { name: "Work", path: "/work" },
        {
          name: projectRecord.title,
          path: projectPath,
        },
      ]),
    ],
  };
}

const metadata = buildProjectMetadata(project);
---

<BaseLayout metadata={metadata}>
  <article>
    <header
      class="mx-auto max-w-2xl px-4 pt-16 sm:px-8 sm:pt-32 lg:max-w-5xl lg:px-12"
    >
      <a
        href="/work"
        class="text-sm font-medium text-zinc-500 transition hover:text-teal-600 dark:text-zinc-400 dark:hover:text-teal-400"
      >
        Back to work
      </a>
      <div class="mt-8 max-w-2xl">
        <p
          class="text-xs font-semibold tracking-[0.28em] text-zinc-500 uppercase dark:text-zinc-400"
        >
          {project.path}
        </p>
        <h1
          class="mt-3 text-4xl font-bold tracking-tight text-zinc-800 sm:text-5xl dark:text-zinc-100"
        >
          {project.title}
        </h1>
        <p class="mt-6 text-base leading-8 text-zinc-600 dark:text-zinc-300">
          {project.description}
        </p>
        <div
          class="mt-8 flex flex-wrap gap-2"
          role="list"
          aria-label={`${project.title} tags`}
        >
          {
            project.tags.map((tag) => (
              <span
                class="rounded-full border border-zinc-200 px-3 py-1.5 text-xs text-zinc-500 dark:border-zinc-700/60 dark:text-zinc-400"
                role="listitem"
              >
                {tag}
              </span>
            ))
          }
        </div>
      </div>
    </header>

    <SplitSection
      title="Problem"
      intro="The delivery or product-system constraint that made the work necessary."
      sectionClass="mt-20"
    >
      <p class="text-sm leading-7 text-zinc-600 dark:text-zinc-300">
        {project.caseStudy.problem}
      </p>
    </SplitSection>

    <SplitSection
      title="Role"
      intro="Where I sat in the implementation and decision-making loop."
      sectionClass="mt-20"
    >
      <p class="text-sm leading-7 text-zinc-600 dark:text-zinc-300">
        {project.caseStudy.role}
      </p>
    </SplitSection>

    <SplitSection
      title="Decisions"
      intro="The architectural and product choices that carried the outcome."
      sectionClass="mt-20"
    >
      <div class="space-y-6">
        {
          project.caseStudy.decisions.map((decision) => (
            <p class="text-sm leading-7 text-zinc-600 dark:text-zinc-300">
              {decision}
            </p>
          ))
        }
      </div>
    </SplitSection>

    <SplitSection
      title="Outcome"
      intro="The practical result of the work once the main implementation decisions were in place."
      sectionClass="mt-20"
    >
      <p class="text-sm leading-7 text-zinc-600 dark:text-zinc-300">
        {project.caseStudy.outcome}
      </p>
    </SplitSection>

    <SplitSection
      title="Proof points"
      intro="Signals that show what changed, what shipped, or what got easier to sustain."
      sectionClass="mt-20"
    >
      <ul class="space-y-3 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
        {project.caseStudy.proof.map((proofPoint) => <li>{proofPoint}</li>)}
      </ul>
    </SplitSection>
  </article>

  <CTA
    eyebrow="Similar constraint?"
    title="Bring the product surface and the delivery risk."
    body="A useful first conversation starts with the workflow that is getting harder to extend, the constraints around it, and the outcome that needs to be true after the work."
    primaryHref="/contact"
    primaryLabel="Start a conversation"
    secondaryHref="/capabilities"
    secondaryLabel="View capabilities"
  />
</BaseLayout>
