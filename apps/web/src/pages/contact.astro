---
/**
 * @file apps/web/src/pages/contact.astro
 * @author Guy Romelle Magayano
 * @description Contact page for collaboration paths and direct outreach.
 */

import PageIntro from "@web/components/PageIntro.astro";
import SplitSection from "@web/components/SplitSection.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { bookingPaths, services } from "@web/data/services";
import {
  buildPortfolioPageMetadata,
  getPortfolioBrochurePage,
  getPortfolioSocialLinkByPlatform,
} from "@web/lib/portfolio-brochure";
import {
  appendStructuredData,
  buildContactPageStructuredData,
} from "@web/lib/structured-data";

const { page } = await getPortfolioBrochurePage("contact");
const metadata = appendStructuredData(
  buildPortfolioPageMetadata(page),
  buildContactPageStructuredData(page)
);
const emailLink = getPortfolioSocialLinkByPlatform("email");
const githubLink = getPortfolioSocialLinkByPlatform("github");
const linkedinLink = getPortfolioSocialLinkByPlatform("linkedin");
---

<BaseLayout metadata={metadata}>
  <PageIntro
    subheading={page.subheading}
    title={page.title}
    intro={page.intro}
  />

  <SplitSection
    title="Choose the conversation shape"
    intro="The clearest first message usually maps to one of these engagement modes."
    sectionClass="mt-16"
  >
    <div class="grid gap-6 sm:grid-cols-3">
      {
        bookingPaths.map((bookingPath) => (
          <article class="rounded-2xl border border-zinc-100 p-5 dark:border-zinc-800">
            <h3 class="text-base font-semibold text-zinc-800 dark:text-zinc-100">
              {bookingPath.title}
            </h3>
            <p class="mt-3 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
              {bookingPath.description}
            </p>
          </article>
        ))
      }
    </div>
  </SplitSection>

  <SplitSection
    title="Start with direct context"
    intro="The useful first message includes the product surface, the delivery risk, what changed, and what outcome would make the work worthwhile."
    sectionClass="mt-20"
  >
    <div
      class="rounded-2xl border border-zinc-100 p-6 sm:p-8 dark:border-zinc-800"
    >
      <div class="flex flex-wrap gap-3">
        {
          emailLink ? (
            <a
              href={emailLink.href}
              class="inline-flex items-center justify-center rounded-full bg-zinc-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-zinc-700"
              data-analytics-content-id="direct-email"
              data-analytics-content-name="Email me directly"
              data-analytics-content-type="contact"
              data-analytics-event="generate_lead"
              data-analytics-lead-type="direct_contact"
              data-analytics-method="email"
              data-analytics-placement="contact-primary"
            >
              Email me directly
            </a>
          ) : null
        }
        {
          linkedinLink ? (
            <a
              href={linkedinLink.href}
              rel="noopener noreferrer"
              target="_blank"
              class="inline-flex items-center justify-center rounded-full border border-zinc-200 bg-white px-5 py-3 text-sm font-medium text-zinc-800 transition hover:border-zinc-300 dark:border-zinc-700/60 dark:bg-zinc-900 dark:text-zinc-100 dark:hover:border-zinc-600"
              data-analytics-content-id="linkedin-contact"
              data-analytics-content-name="Open LinkedIn"
              data-analytics-content-type="contact"
              data-analytics-event="generate_lead"
              data-analytics-lead-type="social_contact"
              data-analytics-method="linkedin"
              data-analytics-placement="contact-secondary"
            >
              Open LinkedIn
            </a>
          ) : null
        }
      </div>
    </div>
  </SplitSection>

  <SplitSection
    title="Helpful context to include"
    intro="Most good consulting conversations get clearer faster when the first note is specific."
    sectionClass="mt-20"
  >
    <ul class="space-y-3 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
      <li>The surface or workflow that is getting harder to extend.</li>
      <li>The delivery risk or architectural debt behind the slowdown.</li>
      <li>The timeframe that makes the work useful right now.</li>
      <li>The kind of help you expect: review, advisory, or execution.</li>
    </ul>
  </SplitSection>

  <SplitSection
    title="Public links"
    intro="If you want more context before reaching out, start with the public surfaces below."
    sectionClass="mt-20"
  >
    <div
      class="flex flex-wrap gap-4 text-sm font-medium text-zinc-800 dark:text-zinc-100"
    >
      {
        githubLink ? (
          <a
            href={githubLink.href}
            rel="noopener noreferrer"
            target="_blank"
            class="transition hover:text-teal-600 dark:hover:text-teal-400"
          >
            GitHub
          </a>
        ) : null
      }
      {
        linkedinLink ? (
          <a
            href={linkedinLink.href}
            rel="noopener noreferrer"
            target="_blank"
            class="transition hover:text-teal-600 dark:hover:text-teal-400"
          >
            LinkedIn
          </a>
        ) : null
      }
      <a
        href="/resume.pdf"
        class="transition hover:text-teal-600 dark:hover:text-teal-400"
      >
        Resume
      </a>
    </div>
  </SplitSection>

  <SplitSection
    title="Typical engagement shapes"
    intro="If you already know the mode of help you need, this is the shortest path."
    sectionClass="mt-20 pb-24"
  >
    <div class="space-y-8">
      {
        services.map((service) => (
          <article>
            <h3 class="text-base font-semibold text-zinc-800 dark:text-zinc-100">
              {service.title}
            </h3>
            <p class="mt-2 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
              {service.bestFor}
            </p>
          </article>
        ))
      }
    </div>
  </SplitSection>
</BaseLayout>
