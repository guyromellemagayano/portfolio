---
import PageIntro from "@web/components/PageIntro.astro";
import BaseLayout from "@web/layouts/BaseLayout.astro";
import { services } from "@web/data/services";
import {
  buildPortfolioPageMetadata,
  getPortfolioBrochurePage,
  getPortfolioSocialLinkByPlatform,
} from "@web/lib/portfolio-brochure";
import {
  appendStructuredData,
  buildContactPageStructuredData,
} from "@web/lib/structured-data";

const { page } = await getPortfolioBrochurePage("contact");
const metadata = appendStructuredData(
  buildPortfolioPageMetadata(page),
  buildContactPageStructuredData(page)
);
const emailLink = getPortfolioSocialLinkByPlatform("email");
const githubLink = getPortfolioSocialLinkByPlatform("github");
const linkedinLink = getPortfolioSocialLinkByPlatform("linkedin");
---

<BaseLayout metadata={metadata}>
  <PageIntro
    subheading={page.subheading}
    title={page.title}
    intro={page.intro}
  />

  <section
    aria-labelledby="contact-start-heading"
    class="mx-auto grid max-w-6xl gap-6 px-6 py-12 sm:px-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]"
    role="region"
  >
    <section
      aria-labelledby="contact-start-heading"
      class="rounded-lg border border-zinc-950/10 bg-white p-6 sm:p-8"
      role="region"
    >
      <h2
        id="contact-start-heading"
        class="text-2xl font-medium tracking-tight text-zinc-950"
      >
        Start with direct context
      </h2>
      <p class="mt-3 text-sm leading-7 text-zinc-600">
        Send the system, product surface, role, or delivery risk you want to
        discuss. The useful first message includes what changed, what is at
        stake, and what outcome would make the work worthwhile.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        {
          emailLink ? (
            <a
              href={emailLink.href}
              class="inline-flex items-center justify-center rounded-full bg-zinc-950 px-5 py-3 text-sm font-medium text-white transition hover:bg-zinc-800"
              data-analytics-content-id="direct-email"
              data-analytics-content-name="Email me directly"
              data-analytics-content-type="contact"
              data-analytics-event="generate_lead"
              data-analytics-lead-type="direct_contact"
              data-analytics-method="email"
              data-analytics-placement="contact-primary"
            >
              Email me directly
            </a>
          ) : null
        }
        {
          linkedinLink ? (
            <a
              href={linkedinLink.href}
              rel="noopener noreferrer"
              target="_blank"
              class="inline-flex items-center justify-center rounded-full border border-zinc-950/10 bg-white px-5 py-3 text-sm font-medium text-zinc-950 transition hover:border-zinc-950/30"
              data-analytics-content-id="linkedin-contact"
              data-analytics-content-name="Open LinkedIn"
              data-analytics-content-type="contact"
              data-analytics-event="generate_lead"
              data-analytics-lead-type="social_contact"
              data-analytics-method="linkedin"
              data-analytics-placement="contact-secondary"
            >
              Open LinkedIn
            </a>
          ) : null
        }
      </div>
    </section>

    <aside class="space-y-4">
      <section
        aria-labelledby="contact-guidance-heading"
        class="rounded-lg border border-zinc-950/10 bg-white p-6"
        role="region"
      >
        <h2
          id="contact-guidance-heading"
          class="text-lg font-medium tracking-tight text-zinc-950"
        >
          Helpful context to include
        </h2>
        <ul class="mt-4 space-y-3 text-sm leading-7 text-zinc-600">
          <li>The surface or workflow that is getting harder to extend.</li>
          <li>The delivery risk or architectural debt behind the slowdown.</li>
          <li>The timeframe that makes the work useful right now.</li>
          <li>The kind of help you expect: review, advisory, or execution.</li>
        </ul>
      </section>

      <section
        aria-labelledby="contact-links-heading"
        class="rounded-lg border border-zinc-950/10 bg-white p-6"
        role="region"
      >
        <h2
          id="contact-links-heading"
          class="text-lg font-medium tracking-tight text-zinc-950"
        >
          Public links
        </h2>
        <div class="mt-4 flex flex-wrap gap-3">
          {
            githubLink ? (
              <a
                href={githubLink.href}
                rel="noopener noreferrer"
                target="_blank"
                class="text-sm font-medium text-zinc-950 underline decoration-zinc-300 underline-offset-4"
              >
                GitHub
              </a>
            ) : null
          }
          {
            linkedinLink ? (
              <a
                href={linkedinLink.href}
                rel="noopener noreferrer"
                target="_blank"
                class="text-sm font-medium text-zinc-950 underline decoration-zinc-300 underline-offset-4"
              >
                LinkedIn
              </a>
            ) : null
          }
          <a
            href="/resume.pdf"
            class="text-sm font-medium text-zinc-950 underline decoration-zinc-300 underline-offset-4"
          >
            Resume
          </a>
        </div>
      </section>

      <section
        aria-labelledby="contact-capabilities-heading"
        class="rounded-lg border border-zinc-950/10 bg-white p-6"
        role="region"
      >
        <h2
          id="contact-capabilities-heading"
          class="text-lg font-medium tracking-tight text-zinc-950"
        >
          Typical engagement shapes
        </h2>
        <div class="mt-4 space-y-4">
          {
            services.map((service) => (
              <article class="border-t border-zinc-950/10 pt-4 first:border-t-0 first:pt-0">
                <h3 class="text-sm font-semibold text-zinc-950">
                  {service.title}
                </h3>
                <p class="mt-2 text-sm leading-6 text-zinc-600">
                  {service.bestFor}
                </p>
              </article>
            ))
          }
        </div>
      </section>
    </aside>
  </section>
</BaseLayout>
