---
/**
 * @file apps/web/src/components/SplitSection.astro
 * @author Guy Romelle Magayano
 * @description Two-column section for paired content blocks.
 */

import { Section as UiSection } from "@portfolio/ui";
import Container from "@web/components/Container.astro";
import Eyebrow from "@web/components/Eyebrow.astro";
import Subheading from "@web/components/Subheading.astro";
import Text from "@web/components/Text.astro";

type Props = {
  title: string;
  eyebrow?: string;
  intro?: string;
  id?: string;
  sectionClass?: string;
  contentClass?: string;
};

const {
  title,
  eyebrow,
  intro,
  id,
  sectionClass = "",
  contentClass = "",
} = Astro.props;

const headingId =
  id ||
  `section-${title
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "")}`;
---

<UiSection aria-labelledby={headingId} className={sectionClass} role="region">
  <Container>
    <div
      class="grid grid-cols-1 items-baseline gap-y-8 lg:grid-cols-[minmax(0,16rem)_minmax(0,1fr)] lg:gap-x-12"
    >
      <div>
        {eyebrow ? <Eyebrow as="p">{eyebrow}</Eyebrow> : null}
        <Subheading id={headingId} class="mt-2 max-w-md">
          {title}
        </Subheading>
        {
          intro ? (
            <Text as="p" class="mt-4 max-w-md text-pretty">
              {intro}
            </Text>
          ) : null
        }
      </div>
      <div class={contentClass}>
        <slot />
      </div>
    </div>
  </Container>
</UiSection>
