---
/**
 * @file apps/web/src/components/Navbar.astro
 * @author Guy Romelle Magayano
 * @description Static Astro navbar rendered directly by the site layout.
 */

import { navigationLinks, profile } from "@web/data/site";

const currentPath = Astro.url.pathname;
const navLinks = navigationLinks.filter((link) => link.showInHeader);

function isActivePath(href: string): boolean {
  return currentPath === href || (href !== "/" && currentPath.startsWith(href));
}
---

<header
  class="sticky top-0 z-50 border-b border-zinc-950/10 bg-stone-50/95 backdrop-blur"
>
  <div
    class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-6 px-6 sm:px-8"
  >
    <a
      href="/"
      class="text-sm font-semibold tracking-tight text-zinc-950"
      aria-label={`${profile.name} home`}
    >
      {profile.name}
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Main navigation">
      {
        navLinks.map((link) => {
          const active = isActivePath(link.href);

          return (
            <a
              href={link.href}
              class:list={[
                "text-sm font-medium transition hover:text-zinc-950",
                active ? "text-zinc-950" : "text-zinc-500",
              ]}
              aria-current={active ? "page" : undefined}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <button
      class="inline-flex size-11 items-center justify-center rounded-full border border-zinc-950/10 text-zinc-950 md:hidden"
      type="button"
      aria-label="Open menu"
      aria-controls="mobile-navigation"
      aria-expanded="false"
      data-mobile-menu-open
    >
      <span class="sr-only">Open menu</span>
      <span class="block h-0.5 w-5 bg-current"></span>
    </button>
  </div>
</header>

<div
  id="mobile-navigation"
  class="fixed inset-0 z-[60] hidden bg-stone-50 px-6 py-6 md:hidden"
  aria-hidden="true"
  data-mobile-menu
>
  <div class="flex items-center justify-between">
    <a href="/" class="text-sm font-semibold tracking-tight text-zinc-950">
      {profile.name}
    </a>
    <button
      class="inline-flex size-11 items-center justify-center rounded-full border border-zinc-950/10 text-zinc-950"
      type="button"
      aria-label="Close menu"
      data-mobile-menu-close
    >
      <span aria-hidden="true" class="text-2xl leading-none">&times;</span>
    </button>
  </div>
  <nav class="mt-16 grid gap-6" aria-label="Mobile navigation">
    {
      navLinks.map((link) => {
        const active = isActivePath(link.href);

        return (
          <a
            href={link.href}
            class:list={[
              "text-3xl font-medium tracking-tight",
              active ? "text-zinc-950" : "text-zinc-500",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {link.label}
          </a>
        );
      })
    }
  </nav>
</div>

<script>
  const openButton = document.querySelector("[data-mobile-menu-open]");
  const closeButton = document.querySelector("[data-mobile-menu-close]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");
  const focusableSelector = [
    "a[href]",
    "button:not([disabled])",
    "textarea:not([disabled])",
    "input:not([disabled])",
    "select:not([disabled])",
    "[tabindex]:not([tabindex='-1'])",
  ].join(",");

  function getFocusableMenuElements() {
    return Array.from(
      mobileMenu?.querySelectorAll(focusableSelector) ?? []
    ).filter((element) => {
      return element instanceof HTMLElement && element.offsetParent !== null;
    }) as HTMLElement[];
  }

  function isMobileMenuOpen() {
    return mobileMenu?.getAttribute("aria-hidden") === "false";
  }

  function openMobileMenu() {
    mobileMenu?.classList.remove("hidden");
    mobileMenu?.setAttribute("aria-hidden", "false");
    openButton?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
    (closeButton as HTMLElement | null)?.focus();
  }

  function closeMobileMenu(options = { restoreFocus: true }) {
    if (!isMobileMenuOpen()) {
      return;
    }

    mobileMenu?.classList.add("hidden");
    mobileMenu?.setAttribute("aria-hidden", "true");
    openButton?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";

    if (options.restoreFocus) {
      (openButton as HTMLElement | null)?.focus();
    }
  }

  function keepFocusInsideMobileMenu(event: KeyboardEvent) {
    if (!isMobileMenuOpen() || event.key !== "Tab") {
      return;
    }

    const focusableElements = getFocusableMenuElements();
    const firstElement = focusableElements.at(0);
    const lastElement = focusableElements.at(-1);

    if (!firstElement || !lastElement) {
      event.preventDefault();
      return;
    }

    if (event.shiftKey && document.activeElement === firstElement) {
      event.preventDefault();
      lastElement.focus();
      return;
    }

    if (!event.shiftKey && document.activeElement === lastElement) {
      event.preventDefault();
      firstElement.focus();
    }
  }

  openButton?.addEventListener("click", openMobileMenu);
  closeButton?.addEventListener("click", closeMobileMenu);
  mobileMenu?.addEventListener("click", (event) => {
    if ((event.target as Element | null)?.closest("a")) {
      closeMobileMenu({ restoreFocus: false });
    }
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeMobileMenu();
      return;
    }

    keepFocusInsideMobileMenu(event);
  });
</script>
