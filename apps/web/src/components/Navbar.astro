---
/**
 * @file apps/web/src/components/Navbar.astro
 * @author Guy Romelle Magayano
 * @description Static Astro navbar styled after the archived template shell.
 */

import { navigationLinks, profile } from "@web/data/site";
import avatarImage from "@web/images/avatar.jpg";

const currentPath = Astro.url.pathname;
const navLinks = navigationLinks.filter((link) => link.showInHeader);

function isActivePath(href: string): boolean {
  return currentPath === href || (href !== "/" && currentPath.startsWith(href));
}
---

<header class="pointer-events-none relative z-50 flex flex-col">
  <div class="top-0 z-10 h-16 pt-6">
    <div class="sm:px-8">
      <div class="mx-auto w-full max-w-7xl lg:px-8">
        <div class="relative px-4 sm:px-8 lg:px-12">
          <div class="mx-auto max-w-2xl lg:max-w-5xl">
            <div class="relative flex gap-4">
              <div class="flex flex-1">
                <a
                  href="/"
                  class="pointer-events-auto"
                  aria-label={`${profile.name} home`}
                  data-analytics-content-id="/"
                  data-analytics-content-name="Home"
                  data-analytics-content-type="navigation"
                  data-analytics-placement="header-brand"
                >
                  <img
                    src={avatarImage.src}
                    alt=""
                    width={avatarImage.width}
                    height={avatarImage.height}
                    class="h-10 w-10 rounded-full bg-zinc-100 object-cover shadow-lg ring-1 ring-zinc-900/5 dark:bg-zinc-800 dark:ring-white/10"
                  />
                </a>
              </div>

              <div class="flex flex-1 justify-end md:justify-center">
                <button
                  class="group pointer-events-auto inline-flex items-center rounded-full bg-white/90 px-4 py-2 text-sm font-medium text-zinc-800 shadow-lg ring-1 ring-zinc-900/5 backdrop-blur transition md:hidden dark:bg-zinc-800/90 dark:text-zinc-200 dark:ring-white/10 dark:hover:ring-white/20"
                  type="button"
                  aria-label="Open menu"
                  aria-controls="mobile-navigation"
                  aria-expanded="false"
                  data-mobile-menu-open
                >
                  Menu
                  <svg
                    viewBox="0 0 8 6"
                    class="ml-3 h-auto w-2 stroke-zinc-500 group-hover:stroke-zinc-700 dark:group-hover:stroke-zinc-400"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M1.75 1.75 4 4.25l2.25-2.5"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </button>

                <nav
                  class="pointer-events-auto hidden md:block"
                  aria-label="Main navigation"
                >
                  <ul
                    class="flex rounded-full bg-white/90 px-3 text-sm font-medium text-zinc-800 shadow-lg ring-1 ring-zinc-900/5 backdrop-blur dark:bg-zinc-800/90 dark:text-zinc-200 dark:ring-white/10"
                  >
                    {
                      navLinks.map((link) => {
                        const active = isActivePath(link.href);

                        return (
                          <li>
                            <a
                              href={link.href}
                              class:list={[
                                "relative block px-3 py-2 transition hover:text-teal-600 dark:hover:text-teal-400",
                                active
                                  ? "text-teal-600 dark:text-teal-400"
                                  : "text-zinc-800 dark:text-zinc-200",
                              ]}
                              aria-current={active ? "page" : undefined}
                              data-analytics-content-id={link.href}
                              data-analytics-content-name={link.label}
                              data-analytics-content-type="navigation"
                              data-analytics-placement="header-nav"
                            >
                              {link.label}
                              {active ? (
                                <span class="absolute inset-x-1 -bottom-px h-px bg-linear-to-r from-teal-500/0 via-teal-500/40 to-teal-500/0 dark:from-teal-400/0 dark:via-teal-400/40 dark:to-teal-400/0" />
                              ) : null}
                            </a>
                          </li>
                        );
                      })
                    }
                  </ul>
                </nav>
              </div>

              <div class="flex flex-1 justify-end gap-3">
                <button
                  class="group pointer-events-auto inline-flex items-center rounded-full bg-white/90 px-3 py-2 shadow-lg ring-1 ring-zinc-900/5 backdrop-blur-sm transition dark:bg-zinc-800/90 dark:ring-white/10 dark:hover:ring-white/20"
                  type="button"
                  data-theme-toggle
                  aria-label="Toggle theme"
                  title="Toggle theme"
                >
                  <span class="sr-only">Toggle theme</span>
                  <svg
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="h-6 w-6 fill-zinc-100 stroke-zinc-500 transition group-hover:fill-zinc-200 group-hover:stroke-zinc-700 dark:hidden [@media(prefers-color-scheme:dark)]:fill-zinc-50 [@media(prefers-color-scheme:dark)]:stroke-zinc-500 [@media(prefers-color-scheme:dark)]:group-hover:fill-zinc-50 [@media(prefers-color-scheme:dark)]:group-hover:stroke-zinc-600"
                  >
                    <path
                      d="M8 12.25A4.25 4.25 0 0 1 12.25 8v0a4.25 4.25 0 0 1 4.25 4.25v0a4.25 4.25 0 0 1-4.25 4.25v0A4.25 4.25 0 0 1 8 12.25v0Z"
                    ></path>
                    <path
                      d="M12.25 3v1.5M21.5 12.25H20M18.791 18.791l-1.06-1.06M18.791 5.709l-1.06 1.06M12.25 20v1.5M4.5 12.25H3M6.77 6.77 5.709 5.709M6.77 17.73l-1.061 1.061"
                      fill="none"></path>
                  </svg>
                  <svg
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    class="hidden h-6 w-6 fill-zinc-700 stroke-zinc-500 transition not-[@media_(prefers-color-scheme:dark)]:fill-zinc-400/10 not-[@media_(prefers-color-scheme:dark)]:stroke-zinc-500 dark:block [@media(prefers-color-scheme:dark)]:group-hover:stroke-zinc-400"
                  >
                    <path
                      d="M17.25 16.22a6.937 6.937 0 0 1-9.47-9.47 7.451 7.451 0 1 0 9.47 9.47ZM12.75 7C17 7 17 2.75 17 2.75S17 7 21.25 7C17 7 17 11.25 17 11.25S17 7 12.75 7Z"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </button>
                <a
                  href="/contact"
                  class="pointer-events-auto hidden items-center rounded-full bg-white/90 px-4 py-2 text-sm font-medium text-zinc-800 shadow-lg ring-1 ring-zinc-900/5 backdrop-blur transition hover:text-teal-600 lg:inline-flex dark:bg-zinc-800/90 dark:text-zinc-200 dark:ring-white/10 dark:hover:text-teal-400"
                >
                  Start a conversation
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<div
  id="mobile-navigation"
  class="fixed inset-0 z-60 hidden bg-zinc-800/40 px-4 pt-6 backdrop-blur-sm md:hidden dark:bg-black/80"
  aria-hidden="true"
  data-mobile-menu
>
  <div
    class="mx-auto max-w-sm rounded-3xl bg-white p-6 shadow-2xl ring-1 ring-zinc-900/5 dark:bg-zinc-900 dark:ring-zinc-800"
  >
    <div class="flex items-center justify-between">
      <h2 class="text-sm font-medium text-zinc-600 dark:text-zinc-400">
        Navigation
      </h2>
      <button
        class="-m-1 inline-flex size-10 items-center justify-center rounded-full text-zinc-500 dark:text-zinc-400"
        type="button"
        aria-label="Close menu"
        data-mobile-menu-close
      >
        <span aria-hidden="true" class="text-2xl leading-none">&times;</span>
      </button>
    </div>
    <nav class="mt-6" aria-label="Mobile navigation">
      <ul
        class="-my-2 divide-y divide-zinc-100 text-base text-zinc-800 dark:divide-zinc-100/5 dark:text-zinc-300"
      >
        {
          navLinks.map((link) => {
            const active = isActivePath(link.href);

            return (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    "block py-3 transition hover:text-teal-600 dark:hover:text-teal-400",
                    active ? "text-teal-600 dark:text-teal-400" : undefined,
                  ]}
                  aria-current={active ? "page" : undefined}
                  data-analytics-content-id={link.href}
                  data-analytics-content-name={link.label}
                  data-analytics-content-type="navigation"
                  data-analytics-placement="mobile-nav"
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
    <div
      class="mt-6 flex items-center justify-between border-t border-zinc-100 pt-6 dark:border-zinc-700/40"
    >
      <button
        class="group inline-flex items-center rounded-full bg-white/90 px-3 py-2 shadow-lg ring-1 ring-zinc-900/5 backdrop-blur-sm transition dark:bg-zinc-800/90 dark:ring-white/10 dark:hover:ring-white/20"
        type="button"
        data-theme-toggle
        aria-label="Toggle theme"
        title="Toggle theme"
      >
        <span class="sr-only">Toggle theme</span>
        <svg
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="h-6 w-6 fill-zinc-100 stroke-zinc-500 transition group-hover:fill-zinc-200 group-hover:stroke-zinc-700 dark:hidden [@media(prefers-color-scheme:dark)]:fill-zinc-50 [@media(prefers-color-scheme:dark)]:stroke-zinc-500 [@media(prefers-color-scheme:dark)]:group-hover:fill-zinc-50 [@media(prefers-color-scheme:dark)]:group-hover:stroke-zinc-600"
        >
          <path
            d="M8 12.25A4.25 4.25 0 0 1 12.25 8v0a4.25 4.25 0 0 1 4.25 4.25v0a4.25 4.25 0 0 1-4.25 4.25v0A4.25 4.25 0 0 1 8 12.25v0Z"
          ></path>
          <path
            d="M12.25 3v1.5M21.5 12.25H20M18.791 18.791l-1.06-1.06M18.791 5.709l-1.06 1.06M12.25 20v1.5M4.5 12.25H3M6.77 6.77 5.709 5.709M6.77 17.73l-1.061 1.061"
            fill="none"></path>
        </svg>
        <svg
          viewBox="0 0 24 24"
          aria-hidden="true"
          class="hidden h-6 w-6 fill-zinc-700 stroke-zinc-500 transition not-[@media_(prefers-color-scheme:dark)]:fill-zinc-400/10 not-[@media_(prefers-color-scheme:dark)]:stroke-zinc-500 dark:block [@media(prefers-color-scheme:dark)]:group-hover:stroke-zinc-400"
        >
          <path
            d="M17.25 16.22a6.937 6.937 0 0 1-9.47-9.47 7.451 7.451 0 1 0 9.47 9.47ZM12.75 7C17 7 17 2.75 17 2.75S17 7 21.25 7C17 7 17 11.25 17 11.25S17 7 12.75 7Z"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>
      <a
        href="/contact"
        class="text-sm font-medium text-zinc-800 transition hover:text-teal-600 dark:text-zinc-200 dark:hover:text-teal-400"
      >
        Start a conversation
      </a>
    </div>
  </div>
</div>

<script>
  const openButton = document.querySelector("[data-mobile-menu-open]");
  const closeButton = document.querySelector("[data-mobile-menu-close]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");
  const themeToggleButtons = Array.from(
    document.querySelectorAll("[data-theme-toggle]")
  );
  const focusableSelector = [
    "a[href]",
    "button:not([disabled])",
    "textarea:not([disabled])",
    "input:not([disabled])",
    "select:not([disabled])",
    "[tabindex]:not([tabindex='-1'])",
  ].join(",");

  function getFocusableMenuElements() {
    return Array.from(
      mobileMenu?.querySelectorAll(focusableSelector) ?? []
    ).filter((element) => {
      return element instanceof HTMLElement && element.offsetParent !== null;
    }) as HTMLElement[];
  }

  function isMobileMenuOpen() {
    return mobileMenu?.getAttribute("aria-hidden") === "false";
  }

  function openMobileMenu() {
    mobileMenu?.classList.remove("hidden");
    mobileMenu?.setAttribute("aria-hidden", "false");
    openButton?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
    (closeButton as HTMLElement | null)?.focus();
  }

  function closeMobileMenu(options = { restoreFocus: true }) {
    if (!isMobileMenuOpen()) {
      return;
    }

    mobileMenu?.classList.add("hidden");
    mobileMenu?.setAttribute("aria-hidden", "true");
    openButton?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";

    if (options.restoreFocus) {
      (openButton as HTMLElement | null)?.focus();
    }
  }

  function keepFocusInsideMobileMenu(event: KeyboardEvent) {
    if (!isMobileMenuOpen() || event.key !== "Tab") {
      return;
    }

    const focusableElements = getFocusableMenuElements();
    const firstElement = focusableElements.at(0);
    const lastElement = focusableElements.at(-1);

    if (!firstElement || !lastElement) {
      event.preventDefault();
      return;
    }

    if (event.shiftKey && document.activeElement === firstElement) {
      event.preventDefault();
      lastElement.focus();
      return;
    }

    if (!event.shiftKey && document.activeElement === lastElement) {
      event.preventDefault();
      firstElement.focus();
    }
  }

  function getThemeApi() {
    return (
      window as typeof window & {
        __portfolioTheme?: {
          getResolvedTheme?: () => "dark" | "light";
          toggleTheme?: () => void;
        };
      }
    ).__portfolioTheme;
  }

  function updateThemeToggleButtons() {
    const resolvedTheme =
      getThemeApi()?.getResolvedTheme?.() ??
      (document.documentElement.classList.contains("dark") ? "dark" : "light");
    const nextTheme = resolvedTheme === "dark" ? "light" : "dark";
    const label = `Switch to ${nextTheme} mode`;

    themeToggleButtons.forEach((button) => {
      button.setAttribute("aria-label", label);
      button.setAttribute("title", label);
    });
  }

  openButton?.addEventListener("click", openMobileMenu);
  closeButton?.addEventListener("click", closeMobileMenu);
  themeToggleButtons.forEach((button) => {
    button.addEventListener("click", () => {
      getThemeApi()?.toggleTheme?.();
      updateThemeToggleButtons();
    });
  });
  mobileMenu?.addEventListener("click", (event) => {
    if ((event.target as Element | null)?.closest("a")) {
      closeMobileMenu({ restoreFocus: false });
    }
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeMobileMenu();
      return;
    }

    keepFocusInsideMobileMenu(event);
  });
  window.addEventListener("portfolio-theme-change", updateThemeToggleButtons);
  updateThemeToggleButtons();
</script>
