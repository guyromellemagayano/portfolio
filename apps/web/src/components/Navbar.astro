---
/**
 * @file apps/web/src/components/Navbar.astro
 * @author Guy Romelle Magayano
 * @description Primary site navigation with theme and mobile menu controls.
 */

import { navigationLinks, profile } from "@web/data/site";

const currentPath = Astro.url.pathname;
const navLinks = navigationLinks.filter((link) => link.showInHeader);
const mobileNavLinks = [...navLinks, { label: "Contact", href: "/contact" }];
const lightModeLogo = {
  src: "/site-logo-light.svg",
  width: 4289,
  height: 1573,
};
const darkModeLogo = {
  src: "/site-logo-dark.svg",
  width: 4289,
  height: 1573,
};

function isActivePath(href: string): boolean {
  return currentPath === href || (href !== "/" && currentPath.startsWith(href));
}
---

<style is:global>
  :root {
    --scroll-padding-top: 5.25rem;
  }
</style>

<header class="sticky top-0 z-50 bg-mist-100 dark:bg-mist-950">
  <nav aria-label="Main navigation">
    <div
      class="mx-auto flex h-(--scroll-padding-top) max-w-7xl items-center gap-4 px-6 lg:px-10"
    >
      <div class="hidden flex-1 gap-8 lg:flex">
        {
          navLinks.map((link) => {
            const active = isActivePath(link.href);

            return (
              <a
                href={link.href}
                class:list={[
                  "group inline-flex items-center justify-between gap-2 text-3xl/10 font-medium lg:text-sm/7",
                  active
                    ? "text-teal-700 dark:text-teal-300"
                    : "text-mist-950 transition hover:text-mist-700 dark:text-white dark:hover:text-mist-200",
                ]}
                aria-current={active ? "page" : undefined}
                data-analytics-content-id={link.href}
                data-analytics-content-name={link.label}
                data-analytics-content-type="navigation"
                data-analytics-placement="header-nav"
              >
                {link.label}
                <span
                  class="inline-flex p-1.5 opacity-0 transition group-hover:opacity-100 lg:hidden"
                  aria-hidden="true"
                >
                  <svg
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="size-6"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="m8.25 4.5 7.5 7.5-7.5 7.5"
                    />
                  </svg>
                </span>
              </a>
            );
          })
        }
      </div>

      <div class="flex items-center">
        <a
          href="/"
          class="inline-flex items-center"
          aria-label={`${profile.name} home`}
          data-analytics-content-id="/"
          data-analytics-content-name="Home"
          data-analytics-content-type="navigation"
          data-analytics-placement="header-brand"
        >
          <span
            class="mt-2 inline-flex h-10 w-24 items-center"
            aria-hidden="true"
          >
            <img
              src={darkModeLogo.src}
              alt=""
              width={darkModeLogo.width}
              height={darkModeLogo.height}
              decoding="async"
              class="block h-full w-full object-contain dark:hidden"
            />
            <img
              src={lightModeLogo.src}
              alt=""
              width={lightModeLogo.width}
              height={lightModeLogo.height}
              decoding="async"
              class="hidden h-full w-full object-contain dark:block"
            />
          </span>
        </a>
      </div>

      <div class="flex flex-1 items-center justify-end gap-4">
        <div class="flex shrink-0 items-center gap-3 sm:gap-5">
          <button
            class="group inline-flex rounded-full p-1.5 text-mist-950 transition hover:bg-mist-950/10 dark:text-white dark:hover:bg-white/10"
            type="button"
            data-theme-toggle
            aria-label="Toggle theme"
            title="Toggle theme"
          >
            <span class="sr-only">Toggle theme</span>
            <svg
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="size-6 fill-mist-100 stroke-mist-500 transition group-hover:fill-mist-200 group-hover:stroke-mist-700 dark:hidden [@media(prefers-color-scheme:dark)]:fill-mist-50 [@media(prefers-color-scheme:dark)]:stroke-mist-500 [@media(prefers-color-scheme:dark)]:group-hover:fill-mist-50 [@media(prefers-color-scheme:dark)]:group-hover:stroke-mist-600"
            >
              <path
                d="M8 12.25A4.25 4.25 0 0 1 12.25 8v0a4.25 4.25 0 0 1 4.25 4.25v0a4.25 4.25 0 0 1-4.25 4.25v0A4.25 4.25 0 0 1 8 12.25v0Z"
              ></path>
              <path
                d="M12.25 3v1.5M21.5 12.25H20M18.791 18.791l-1.06-1.06M18.791 5.709l-1.06 1.06M12.25 20v1.5M4.5 12.25H3M6.77 6.77 5.709 5.709M6.77 17.73l-1.061 1.061"
                fill="none"></path>
            </svg>
            <svg
              viewBox="0 0 24 24"
              aria-hidden="true"
              class="hidden size-6 fill-mist-700 stroke-mist-500 transition not-[@media_(prefers-color-scheme:dark)]:fill-mist-400/10 not-[@media_(prefers-color-scheme:dark)]:stroke-mist-500 dark:block [@media(prefers-color-scheme:dark)]:group-hover:stroke-mist-400"
            >
              <path
                d="M17.25 16.22a6.937 6.937 0 0 1-9.47-9.47 7.451 7.451 0 1 0 9.47 9.47ZM12.75 7C17 7 17 2.75 17 2.75S17 7 21.25 7C17 7 17 11.25 17 11.25S17 7 12.75 7Z"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </button>
          <a
            href="/contact"
            class="hidden items-center rounded-full bg-mist-950 px-4 py-2 text-sm/6 font-medium text-white transition hover:bg-mist-800 sm:inline-flex dark:bg-white dark:text-mist-950 dark:hover:bg-mist-100"
            data-analytics-content-id="/contact"
            data-analytics-content-name="Start a conversation"
            data-analytics-content-type="navigation"
            data-analytics-placement="header-cta"
          >
            Start a conversation
          </a>
        </div>

        <button
          class="inline-flex rounded-full p-1.5 text-mist-950 transition hover:bg-mist-950/10 lg:hidden dark:text-white dark:hover:bg-white/10"
          type="button"
          aria-label="Toggle menu"
          aria-controls="mobile-navigation"
          aria-expanded="false"
          data-mobile-menu-open
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="size-6">
            <path
              fill-rule="evenodd"
              d="M3.748 8.248a.75.75 0 0 1 .75-.75h15a.75.75 0 0 1 0 1.5h-15a.75.75 0 0 1-.75-.75ZM3.748 15.75a.75.75 0 0 1 .75-.751h15a.75.75 0 0 1 0 1.5h-15a.75.75 0 0 1-.75-.75Z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<div
  id="mobile-navigation"
  class="fixed inset-0 z-60 hidden bg-mist-100 px-6 py-6 lg:hidden dark:bg-mist-950"
  role="dialog"
  aria-modal="true"
  aria-labelledby="mobile-navigation-title"
  aria-hidden="true"
  data-mobile-menu
>
  <div class="flex justify-end">
    <button
      class="inline-flex rounded-full p-1.5 text-mist-950 transition hover:bg-mist-950/10 dark:text-white dark:hover:bg-white/10"
      type="button"
      aria-label="Close menu"
      data-mobile-menu-close
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-6"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18 18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div class="mt-6 flex flex-col gap-6">
    <h2 id="mobile-navigation-title" class="sr-only">Navigation</h2>
    {
      mobileNavLinks.map((link) => {
        const active = isActivePath(link.href);

        return (
          <a
            href={link.href}
            class:list={[
              "group inline-flex items-center justify-between gap-2 text-3xl/10 font-medium",
              active
                ? "text-teal-700 dark:text-teal-300"
                : "text-mist-950 transition hover:text-mist-700 dark:text-white dark:hover:text-mist-200",
            ]}
            aria-current={active ? "page" : undefined}
            data-analytics-content-id={link.href}
            data-analytics-content-name={link.label}
            data-analytics-content-type="navigation"
            data-analytics-placement="mobile-nav"
          >
            {link.label}
            <span
              class="inline-flex p-1.5 opacity-0 transition group-hover:opacity-100"
              aria-hidden="true"
            >
              <svg
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-6"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m8.25 4.5 7.5 7.5-7.5 7.5"
                />
              </svg>
            </span>
          </a>
        );
      })
    }
  </div>
</div>

<script>
  const openButton = document.querySelector("[data-mobile-menu-open]");
  const closeButton = document.querySelector("[data-mobile-menu-close]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");
  const themeToggleButtons = Array.from(
    document.querySelectorAll("[data-theme-toggle]")
  );
  const focusableSelector = [
    "a[href]",
    "button:not([disabled])",
    "textarea:not([disabled])",
    "input:not([disabled])",
    "select:not([disabled])",
    "[tabindex]:not([tabindex='-1'])",
  ].join(",");

  function getFocusableMenuElements() {
    return Array.from(
      mobileMenu?.querySelectorAll(focusableSelector) ?? []
    ).filter((element) => {
      return element instanceof HTMLElement && element.offsetParent !== null;
    }) as HTMLElement[];
  }

  function isMobileMenuOpen() {
    return mobileMenu?.getAttribute("aria-hidden") === "false";
  }

  function openMobileMenu() {
    mobileMenu?.classList.remove("hidden");
    mobileMenu?.setAttribute("aria-hidden", "false");
    openButton?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
    (closeButton as HTMLElement | null)?.focus();
  }

  function closeMobileMenu(options: { restoreFocus?: boolean } = {}) {
    const { restoreFocus = true } = options;

    if (!isMobileMenuOpen()) {
      return;
    }

    mobileMenu?.classList.add("hidden");
    mobileMenu?.setAttribute("aria-hidden", "true");
    openButton?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";

    if (restoreFocus) {
      (openButton as HTMLElement | null)?.focus();
    }
  }

  function keepFocusInsideMobileMenu(event: KeyboardEvent) {
    if (!isMobileMenuOpen() || event.key !== "Tab") {
      return;
    }

    const focusableElements = getFocusableMenuElements();
    const firstElement = focusableElements.at(0);
    const lastElement = focusableElements.at(-1);

    if (!firstElement || !lastElement) {
      event.preventDefault();
      return;
    }

    if (event.shiftKey && document.activeElement === firstElement) {
      event.preventDefault();
      lastElement.focus();
      return;
    }

    if (!event.shiftKey && document.activeElement === lastElement) {
      event.preventDefault();
      firstElement.focus();
    }
  }

  function getThemeApi() {
    return (
      window as typeof window & {
        __portfolioTheme?: {
          getResolvedTheme?: () => "dark" | "light";
          toggleTheme?: () => void;
        };
      }
    ).__portfolioTheme;
  }

  function updateThemeToggleButtons() {
    const resolvedTheme =
      getThemeApi()?.getResolvedTheme?.() ??
      (document.documentElement.classList.contains("dark") ? "dark" : "light");
    const nextTheme = resolvedTheme === "dark" ? "light" : "dark";
    const label = `Switch to ${nextTheme} mode`;

    themeToggleButtons.forEach((button) => {
      button.setAttribute("aria-label", label);
      button.setAttribute("title", label);
    });
  }

  openButton?.addEventListener("click", openMobileMenu);
  closeButton?.addEventListener("click", () => {
    closeMobileMenu();
  });
  themeToggleButtons.forEach((button) => {
    button.addEventListener("click", () => {
      getThemeApi()?.toggleTheme?.();
      updateThemeToggleButtons();
    });
  });
  mobileMenu?.addEventListener("click", (event) => {
    if ((event.target as Element | null)?.closest("a")) {
      closeMobileMenu({ restoreFocus: false });
    }
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeMobileMenu();
      return;
    }

    keepFocusInsideMobileMenu(event);
  });
  window.addEventListener("portfolio-theme-change", updateThemeToggleButtons);
  updateThemeToggleButtons();
</script>
