---
/**
 * @file apps/web/src/components/Eyebrow.astro
 * @author Guy Romelle Magayano
 * @description Astro-native eyebrow text primitive ported from the archived demo elements.
 */

const { as: Component = "div", class: className = "", ...rest } = Astro.props;
---

<Component
  {...rest}
  class:list={[
    "text-sm/7 font-semibold text-mist-700 dark:text-mist-400",
    className,
  ]}
>
  <slot />
</Component>
