---
/**
 * @file apps/web/src/components/PathwayCards.astro
 * @author Guy Romelle Magayano
 * @description Reusable Astro cross-link section for portfolio information architecture.
 */

import { type SitePathway } from "@web/data/site";

type Props = {
  eyebrow?: string;
  id: string;
  intro?: string;
  pathways: SitePathway[];
  sectionClass?: string;
  title: string;
};

const { eyebrow, id, intro, pathways, sectionClass, title } = Astro.props;
---

<section
  aria-labelledby={id}
  class:list={[
    "mx-auto max-w-2xl px-4 sm:px-8 lg:max-w-5xl lg:px-12",
    sectionClass,
  ]}
>
  <div class="max-w-2xl">
    {
      eyebrow ? (
        <p class="text-xs font-semibold tracking-[0.28em] text-zinc-500 uppercase dark:text-zinc-400">
          {eyebrow}
        </p>
      ) : null
    }
    <h2
      id={id}
      class="mt-3 text-2xl font-semibold tracking-tight text-zinc-800 sm:text-3xl dark:text-zinc-100"
    >
      {title}
    </h2>
    {
      intro ? (
        <p class="mt-4 text-sm leading-7 text-zinc-600 dark:text-zinc-400">
          {intro}
        </p>
      ) : null
    }
  </div>

  <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
    {
      pathways.map((pathway) => (
        <li>
          <a
            href={pathway.href}
            class="group block h-full rounded-2xl border border-zinc-100 p-6 transition hover:border-zinc-200 hover:bg-zinc-50 dark:border-zinc-800 dark:hover:border-zinc-700 dark:hover:bg-zinc-800/50"
          >
            <span class="block text-base font-semibold text-zinc-800 dark:text-zinc-100">
              {pathway.title}
            </span>
            <span class="mt-3 block text-sm leading-7 text-zinc-600 dark:text-zinc-400">
              {pathway.description}
            </span>
            <span class="mt-5 inline-flex text-sm font-medium text-teal-600 dark:text-teal-400">
              {pathway.cta}
              <span
                aria-hidden="true"
                class="ml-1 transition group-hover:translate-x-0.5"
              >
                -&gt;
              </span>
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</section>
