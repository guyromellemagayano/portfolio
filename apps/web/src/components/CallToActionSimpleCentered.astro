---
/**
 * @file apps/web/src/components/CallToActionSimpleCentered.astro
 * @author Guy Romelle Magayano
 * @description Centered call-to-action section with headline and copy.
 */

import { Section as UiSection } from "@portfolio/ui";
import Container from "@web/components/Container.astro";
import Subheading from "@web/components/Subheading.astro";
import Text from "@web/components/Text.astro";

type Props = {
  headline?: string;
  headlineId?: string;
  subheadline?: string;
  class?: string;
  containerClass?: string;
  headlineClass?: string;
  subheadlineClass?: string;
  "aria-labelledby"?: string;
};

const {
  "aria-labelledby": ariaLabelledBy,
  headline,
  headlineId,
  subheadline,
  class: className = "",
  containerClass = "",
  headlineClass = "",
  subheadlineClass = "",
  ...rest
} = Astro.props;

const labelledBy =
  ariaLabelledBy ??
  (headlineId && (headline || Astro.slots.has("headline"))
    ? headlineId
    : undefined);
const sectionClass = ["py-16", className].filter(Boolean).join(" ");
---

<UiSection {...rest} aria-labelledby={labelledBy} className={sectionClass}>
  <Container class:list={["flex flex-col items-center gap-10", containerClass]}>
    <div class="flex flex-col gap-6">
      {
        Astro.slots.has("headline") ? (
          <slot name="headline" />
        ) : headline ? (
          <Subheading
            id={headlineId}
            class:list={["max-w-4xl text-center", headlineClass]}
          >
            {headline}
          </Subheading>
        ) : null
      }

      {
        Astro.slots.has("subheadline") ? (
          <slot name="subheadline" />
        ) : subheadline ? (
          <Text
            as="div"
            class:list={[
              "flex max-w-3xl flex-col gap-4 text-center text-pretty",
              subheadlineClass,
            ]}
          >
            {subheadline}
          </Text>
        ) : null
      }
    </div>

    <slot name="cta" />
  </Container>
</UiSection>
