---
/**
 * @file apps/web/src/components/ServiceCard.astro
 * @author Guy Romelle Magayano
 * @description Static Astro service card rendered from local service data.
 */

import type { Service } from "@web/data/services";

type Props = {
  service: Service;
  showPrice?: boolean;
};

const { service, showPrice = false } = Astro.props;
---

<article
  id={service.id}
  class="rounded-lg border border-zinc-950/10 bg-white p-6"
>
  <p class="text-xs font-semibold tracking-[0.24em] text-zinc-500 uppercase">
    {service.icon}
  </p>
  <h3 class="mt-3 text-xl font-medium tracking-tight text-zinc-950">
    {service.title}
  </h3>
  <p class="mt-3 text-sm leading-7 text-zinc-600">
    {service.description}
  </p>
  {
    showPrice ? (
      <p class="mt-5 text-lg font-medium text-zinc-950">
        {service.price}
        {service.priceNote ? (
          <span class="ml-2 text-sm font-normal text-zinc-500">
            {service.priceNote}
          </span>
        ) : null}
      </p>
    ) : null
  }
  <ul
    aria-label={`${service.title} deliverables`}
    class="mt-5 space-y-2 text-sm leading-6 text-zinc-600"
    role="list"
  >
    {service.bullets.map((deliverable) => <li>{deliverable}</li>)}
  </ul>
  <p class="mt-5 text-sm leading-6 text-zinc-500">
    <span class="font-medium text-zinc-950">Best for:</span>
    {service.bestFor}
  </p>
  <a
    href={service.href}
    class="mt-5 inline-flex text-sm font-medium text-zinc-950 underline decoration-zinc-300 underline-offset-4"
  >
    {service.cta}
  </a>
</article>
