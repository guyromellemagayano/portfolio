---
/**
 * @file apps/web/src/components/ServiceCard.astro
 * @author Guy Romelle Magayano
 * @description Card preview for a service offering.
 */

import { Card as UiCard, Link as UiLink } from "@portfolio/ui";

import { type Service } from "@web/data/services";

type Props = {
  service: Service;
  showPrice?: boolean;
};

const { service, showPrice = false } = Astro.props;
const titleLinkClasses =
  "rounded-sm text-inherit no-underline transition hover:text-teal-600 hover:no-underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-600 dark:focus-visible:outline-teal-400";
---

<UiCard
  as="article"
  id={service.id}
  className="group relative flex flex-col items-start rounded-none border-0 bg-transparent p-0 text-inherit shadow-none"
  data-analytics-content-id={service.id}
  data-analytics-content-name={service.title}
  data-analytics-impression="service"
>
  <div
    aria-hidden="true"
    class="absolute -inset-x-4 -inset-y-6 z-0 scale-95 rounded-lg bg-zinc-50 opacity-0 transition duration-200 group-hover:scale-100 group-hover:opacity-100 sm:-inset-x-6 dark:bg-zinc-800/50"
  >
  </div>
  <p
    class="relative z-10 text-xs font-semibold tracking-[0.24em] text-zinc-500 uppercase dark:text-zinc-400"
  >
    {service.icon}
  </p>
  <h3
    class="relative z-10 mt-4 text-base font-semibold tracking-tight text-zinc-800 dark:text-zinc-100"
  >
    <UiLink
      href={service.href}
      variant={null}
      className={titleLinkClasses}
      data-analytics-content-id={service.id}
      data-analytics-content-name={service.title}
      data-analytics-content-type="service"
      data-analytics-placement="service-card-title"
    >
      {service.title}
    </UiLink>
  </h3>
  <p
    class="relative z-10 mt-2 text-sm leading-7 text-zinc-600 dark:text-zinc-400"
  >
    {service.description}
  </p>
  {
    showPrice ? (
      <p class="relative z-10 mt-5 text-lg font-medium text-zinc-800 dark:text-zinc-100">
        {service.price}
        {service.priceNote ? (
          <span class="ml-2 text-sm font-normal text-zinc-500 dark:text-zinc-400">
            {service.priceNote}
          </span>
        ) : null}
      </p>
    ) : null
  }
  <ul
    aria-label={`${service.title} deliverables`}
    class="relative z-10 mt-5 space-y-2 text-sm leading-6 text-zinc-600 dark:text-zinc-400"
    role="list"
  >
    {service.bullets.map((deliverable) => <li>{deliverable}</li>)}
  </ul>
  <div
    class="relative z-10 mt-6 border-t border-zinc-100 pt-5 dark:border-zinc-700/40"
  >
    <h4 class="text-sm font-semibold text-zinc-950 dark:text-zinc-100">
      Expected outcomes
    </h4>
    <ul
      class="mt-3 space-y-2 text-sm leading-6 text-zinc-600 dark:text-zinc-400"
      role="list"
    >
      {service.outcomes.slice(0, 2).map((outcome) => <li>{outcome}</li>)}
    </ul>
  </div>
  <p
    class="relative z-10 mt-5 text-sm leading-6 text-zinc-500 dark:text-zinc-400"
  >
    <span class="font-medium text-zinc-950 dark:text-zinc-100">Best for:</span>
    {service.bestFor}
  </p>
  <span
    aria-hidden="true"
    class="relative z-10 mt-5 inline-flex items-center text-sm font-medium text-teal-600"
  >
    {service.cta}
    <svg viewBox="0 0 16 16" fill="none" class="ml-1 h-4 w-4 stroke-current">
      <path
        d="M6.75 5.75 9.25 8l-2.5 2.25"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </span>
</UiCard>
