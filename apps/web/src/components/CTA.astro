---
/**
 * @file apps/web/src/components/CTA.astro
 * @author Guy Romelle Magayano
 * @description Astro call-to-action section backed by the archived simple CTA pattern.
 */

import ButtonLink from "@web/components/ButtonLink.astro";
import CallToActionSimple from "@web/components/CallToActionSimple.astro";
import PlainButtonLink from "@web/components/PlainButtonLink.astro";

type Props = {
  eyebrow?: string;
  title: string;
  body: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
};

const {
  eyebrow,
  title,
  body,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<CallToActionSimple
  aria-labelledby="cta-heading"
  class="border-t border-zinc-950/10"
  data-analytics-content-id={primaryHref}
  data-analytics-content-name={title}
  data-analytics-impression="call_to_action"
  data-analytics-placement="cta"
  eyebrow={eyebrow}
  headline={title}
  headlineId="cta-heading"
  role="region"
  subheadline={body}
>
  <div slot="cta" class="flex flex-wrap gap-3">
    <ButtonLink
      href={primaryHref}
      size="lg"
      data-analytics-content-id={primaryHref}
      data-analytics-content-name={primaryLabel}
      data-analytics-content-type="call_to_action"
      data-analytics-placement="cta-primary"
    >
      {primaryLabel}
    </ButtonLink>

    {
      secondaryHref && secondaryLabel ? (
        <PlainButtonLink
          href={secondaryHref}
          size="lg"
          data-analytics-content-id={secondaryHref}
          data-analytics-content-name={secondaryLabel}
          data-analytics-content-type="call_to_action"
          data-analytics-placement="cta-secondary"
        >
          {secondaryLabel}
        </PlainButtonLink>
      ) : null
    }
  </div>
</CallToActionSimple>
