---
/**
 * @file apps/web/src/components/RichText.astro
 * @author Guy Romelle Magayano
 * @description Renderer for rich-text blocks from local content records.
 */

import { Figure as UiFigure, Prose as UiProse } from "@portfolio/ui";

import {
  type ContentPortableTextBlock,
  type ContentPortableTextImageBlock,
} from "@web/data/portable-text";

type Props = {
  value: Array<ContentPortableTextBlock | ContentPortableTextImageBlock>;
  fallbackImageAlt?: string;
};

const { value, fallbackImageAlt = "" } = Astro.props;

function getBlockText(block: ContentPortableTextBlock): string {
  return (block.children || []).map((child) => child.text).join("");
}
---

<UiProse readable={false} className="contents">
  {
    value.map((block) => {
      if (block._type === "image") {
        const image = block as ContentPortableTextImageBlock;
        const src = image.asset?.url;

        if (!src) {
          return null;
        }

        return (
          <UiFigure className="not-prose my-8 overflow-hidden rounded-lg border border-zinc-200/60 bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-900">
            <img
              src={src}
              alt={image.alt || fallbackImageAlt}
              class="h-auto w-full object-cover"
              width={image.asset?.width || 1600}
              height={image.asset?.height || 900}
              loading="lazy"
            />
          </UiFigure>
        );
      }

      const text = getBlockText(block as ContentPortableTextBlock);

      if (!text) {
        return null;
      }

      return <p>{text}</p>;
    })
  }
</UiProse>
