---
/**
 * @file apps/web/src/components/ButtonLink.astro
 * @author Guy Romelle Magayano
 * @description Filled link for primary calls to action.
 */

const {
  href: rawHref,
  size = "md",
  color = "dark/light",
  target,
  rel,
  class: className = "",
  ...rest
} = Astro.props;

const href =
  typeof rawHref === "string" && rawHref.trim().length > 0 ? rawHref : "#";
const sizeClass = size === "lg" ? "px-4 py-2" : "px-3 py-1";
const isExternalHref = /^https?:\/\//i.test(href);
const resolvedTarget = target ?? (isExternalHref ? "_blank" : undefined);
const resolvedRel =
  rel ?? (resolvedTarget === "_blank" ? "noopener noreferrer" : undefined);
---

<a
  {...rest}
  href={href}
  target={resolvedTarget}
  rel={resolvedRel}
  class:list={[
    "inline-flex shrink-0 items-center justify-center gap-1 rounded-full text-sm/7 font-medium transition",
    color === "dark/light" &&
      "bg-mist-950 text-white hover:bg-mist-800 dark:bg-mist-300 dark:text-mist-950 dark:hover:bg-mist-200",
    color === "light" &&
      "bg-white text-mist-950 hover:bg-mist-100 dark:bg-mist-100 dark:hover:bg-white",
    sizeClass,
    className,
  ]}
>
  <slot />
</a>
