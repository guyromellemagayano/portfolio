---
/**
 * @file apps/web/src/components/Button.astro
 * @author Guy Romelle Magayano
 * @description Button primitive for actions and form submission.
 */

import { Button as UiButton } from "@portfolio/ui";

const {
  size = "md",
  type = "button",
  color = "dark/light",
  class: className = "",
  ...rest
} = Astro.props;

const sizeClass = size === "lg" ? "px-4 py-2" : "px-3 py-1";
const classes = [
  "inline-flex shrink-0 items-center justify-center gap-1 rounded-full text-sm/7 font-medium transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-600 disabled:pointer-events-none disabled:opacity-50 dark:focus-visible:outline-teal-400",
  color === "dark/light" &&
    "bg-button text-white hover:bg-button-hover dark:bg-button dark:text-white dark:hover:bg-button-hover",
  color === "light" &&
    "bg-button text-white hover:bg-button-hover dark:bg-button dark:text-white dark:hover:bg-button-hover",
  sizeClass,
  className,
]
  .filter(Boolean)
  .join(" ");
---

<UiButton {...rest} type={type} size={null} variant={null} className={classes}>
  <slot />
</UiButton>
