---
/**
 * @file apps/web/src/components/Button.astro
 * @author Guy Romelle Magayano
 * @description Button primitive for actions and form submission.
 */

const {
  size = "md",
  type = "button",
  color = "dark/light",
  class: className = "",
  ...rest
} = Astro.props;

const sizeClass = size === "lg" ? "px-4 py-2" : "px-3 py-1";
---

<button
  {...rest}
  type={type}
  class:list={[
    "inline-flex shrink-0 items-center justify-center gap-1 rounded-full text-sm/7 font-medium transition",
    color === "dark/light" &&
      "bg-mist-950 text-white hover:bg-mist-800 dark:bg-mist-300 dark:text-mist-950 dark:hover:bg-mist-200",
    color === "light" &&
      "bg-white text-mist-950 hover:bg-mist-100 dark:bg-mist-100 dark:hover:bg-white",
    sizeClass,
    className,
  ]}
>
  <slot />
</button>
