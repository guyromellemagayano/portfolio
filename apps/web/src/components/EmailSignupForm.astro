---
/**
 * @file apps/web/src/components/EmailSignupForm.astro
 * @author Guy Romelle Magayano
 * @description Email signup form with a single input and submit button.
 */

import { FieldLabel, Input as UiInput } from "@portfolio/ui";
import Button from "@web/components/Button.astro";

const {
  action = "/thank-you",
  method = "post",
  label = "Email address",
  placeholder = "Enter your email",
  cta = "Join",
  variant = "normal",
  inputId = "email-signup",
  class: className = "",
  ...rest
} = Astro.props;

const inputClasses = [
  "min-w-0 flex-1 bg-transparent px-3 text-sm/7 focus:outline-hidden",
  variant === "normal" &&
    "text-mist-950 placeholder:text-mist-500 dark:text-white dark:placeholder:text-mist-400",
  variant === "overlay" && "text-white placeholder:text-white/60",
]
  .filter(Boolean)
  .join(" ");
---

<form
  {...rest}
  action={action}
  method={method}
  class:list={[
    "flex rounded-full p-1 ring-1 dark:bg-white/10 dark:ring-white/10",
    variant === "normal" && "bg-white ring-black/10",
    variant === "overlay" && "bg-white/15 ring-white/10",
    className,
  ]}
>
  <FieldLabel htmlFor={inputId} className="sr-only">{label}</FieldLabel>
  <UiInput
    id={inputId}
    className={inputClasses}
    type="email"
    name="email"
    autoComplete="email"
    inputMode="email"
    spellCheck={false}
    required
    aria-label={label}
    placeholder={placeholder}
  />
  <Button color={variant === "normal" ? "dark/light" : "light"} type="submit">
    {cta}
  </Button>
</form>
