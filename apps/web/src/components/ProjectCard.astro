---
/**
 * @file apps/web/src/components/ProjectCard.astro
 * @author Guy Romelle Magayano
 * @description Static Astro project card rendered from local project data.
 */

import { getProjectPath, type Project } from "@web/data/projects";

type Props = {
  project: Project;
  compact?: boolean;
  idPrefix?: string;
};

const { project, compact = false, idPrefix = "" } = Astro.props;
const articleId = idPrefix ? `${idPrefix}-${project.slug}` : project.slug;
const projectPath = getProjectPath(project);
const analyticsContentType = project.kind === "lab" ? "lab" : "work";
---

<article
  id={articleId}
  class="rounded-lg border border-zinc-950/10 bg-white p-6"
  data-analytics-content-id={project.slug}
  data-analytics-content-name={project.title}
  data-analytics-impression="project"
>
  <p class="text-xs font-semibold tracking-[0.24em] text-zinc-500 uppercase">
    {project.path}
  </p>
  <h3 class="mt-3 text-xl font-medium tracking-tight text-zinc-950">
    <a
      href={projectPath}
      data-analytics-content-id={project.slug}
      data-analytics-content-name={project.title}
      data-analytics-content-type={analyticsContentType}
      data-analytics-placement="project-card-title"
    >
      {project.title}
    </a>
  </h3>
  <p class="mt-3 text-sm leading-7 text-zinc-600">
    {project.description}
  </p>
  {
    compact ? null : (
      <ul
        aria-label={`${project.title} proof points`}
        class="mt-5 space-y-2 text-sm leading-6 text-zinc-600"
        role="list"
      >
        {project.bullets.map((proofPoint) => (
          <li>{proofPoint}</li>
        ))}
      </ul>
    )
  }
  <div
    class="mt-5 flex flex-wrap gap-2"
    role="list"
    aria-label={`${project.title} tags`}
  >
    {
      project.tags.map((tag) => (
        <span
          class="rounded-full border border-zinc-950/10 px-3 py-2 text-xs text-zinc-600"
          role="listitem"
        >
          {tag}
        </span>
      ))
    }
  </div>
  <a
    href={projectPath}
    class="mt-5 inline-flex text-sm font-medium text-zinc-950 underline decoration-zinc-300 underline-offset-4"
    data-analytics-content-id={project.slug}
    data-analytics-content-name={project.title}
    data-analytics-content-type={analyticsContentType}
    data-analytics-placement="project-card-cta"
  >
    {project.kind === "lab" ? "Explore lab" : "Read case study"}
  </a>
</article>
