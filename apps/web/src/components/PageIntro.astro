---
/**
 * @file apps/web/src/components/PageIntro.astro
 * @author Guy Romelle Magayano
 * @description Intro block for page titles, summaries, and context.
 */

import { Section as UiSection } from "@portfolio/ui";

import Container from "@web/components/Container.astro";
import Eyebrow from "@web/components/Eyebrow.astro";
import Heading from "@web/components/Heading.astro";
import Text from "@web/components/Text.astro";

type Props = {
  subheading?: string;
  title: string;
  intro?: string;
};

const { subheading, title, intro } = Astro.props;

const headingId = `page-intro-${title
  .trim()
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, "-")
  .replace(/^-+|-+$/g, "")}`;
---

<UiSection as="header" aria-labelledby={headingId} className="space-y-0">
  <Container class="pt-16 sm:pt-32">
    {subheading ? <Eyebrow as="p">{subheading}</Eyebrow> : null}
    <Heading id={headingId} class="mt-3 max-w-2xl sm:max-w-3xl">
      {title}
    </Heading>
    {
      intro ? (
        <Text as="p" size="lg" class="mt-6 max-w-2xl">
          {intro}
        </Text>
      ) : null
    }
  </Container>
</UiSection>
