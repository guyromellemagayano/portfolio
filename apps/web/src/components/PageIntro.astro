---
/**
 * @file apps/web/src/components/PageIntro.astro
 * @author Guy Romelle Magayano
 * @description Shared Astro page intro block ported from the archived template layout.
 */

type Props = {
  subheading?: string;
  title: string;
  intro?: string;
};

const { subheading, title, intro } = Astro.props;
---

<header
  class="mx-auto max-w-2xl px-4 pt-16 sm:px-8 sm:pt-32 lg:max-w-5xl lg:px-12"
>
  {
    subheading ? (
      <p class="text-xs font-semibold tracking-[0.28em] text-zinc-500 uppercase dark:text-zinc-400">
        {subheading}
      </p>
    ) : null
  }
  <h1
    class="mt-3 max-w-2xl text-4xl font-bold tracking-tight text-zinc-800 sm:text-5xl dark:text-zinc-100"
  >
    {title}
  </h1>
  {
    intro ? (
      <p class="mt-6 max-w-2xl text-base leading-8 text-zinc-600 dark:text-zinc-400">
        {intro}
      </p>
    ) : null
  }
</header>
