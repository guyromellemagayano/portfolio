---
/**
 * @file apps/web/src/components/PlainButtonLink.astro
 * @author Guy Romelle Magayano
 * @description Text-forward link for secondary calls to action.
 */

import { Link as UiLink } from "@portfolio/ui";

const {
  href: rawHref,
  size = "md",
  color = "dark/light",
  target,
  rel,
  class: className = "",
  ...rest
} = Astro.props;

const href =
  typeof rawHref === "string" && rawHref.trim().length > 0 ? rawHref : "#";
const sizeClass = size === "lg" ? "px-4 py-2" : "px-3 py-1";
const isExternalHref = /^https?:\/\//i.test(href);
const resolvedTarget = target ?? (isExternalHref ? "_blank" : undefined);
const resolvedRel =
  rel ?? (resolvedTarget === "_blank" ? "noopener noreferrer" : undefined);
const classes = [
  "inline-flex shrink-0 items-center justify-center gap-2 rounded-full text-sm/7 font-medium no-underline transition hover:no-underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-600 dark:focus-visible:outline-teal-400",
  color === "dark/light" &&
    "bg-button text-white hover:bg-button-hover dark:bg-button dark:text-white dark:hover:bg-button-hover",
  color === "light" &&
    "bg-button text-white hover:bg-button-hover dark:bg-button dark:text-white dark:hover:bg-button-hover",
  sizeClass,
  className,
]
  .filter(Boolean)
  .join(" ");
---

<UiLink
  {...rest}
  href={href}
  target={resolvedTarget}
  rel={resolvedRel}
  external={isExternalHref}
  newTab={resolvedTarget === "_blank"}
  variant={null}
  className={classes}
>
  <slot />
</UiLink>
