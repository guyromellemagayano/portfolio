---
/**
 * @file apps/web/src/components/ArticleCard.astro
 * @author Guy Romelle Magayano
 * @description Static Astro article card rendered from local article data using the archived template style.
 */

import { type ArticleWithSlug } from "@web/utils/articles";
import { formatDate } from "@web/lib/format-date";

type Props = {
  article: ArticleWithSlug;
};

const { article } = Astro.props;
const formattedDate = formatDate(article.date);
---

<article
  class="group relative flex flex-col items-start"
  data-analytics-content-id={article.slug}
  data-analytics-content-name={article.title}
  data-analytics-impression="article"
>
  <div
    aria-hidden="true"
    class="absolute -inset-x-4 -inset-y-6 z-0 scale-95 rounded-2xl bg-zinc-50 opacity-0 transition duration-200 group-hover:scale-100 group-hover:opacity-100 sm:-inset-x-6 dark:bg-zinc-800/50"
  >
  </div>
  <div
    class="relative z-10 flex flex-wrap items-center gap-2"
    role="list"
    aria-label={`${article.title} tags`}
  >
    {
      (article.tags || []).slice(0, 2).map((tag) => (
        <span
          class="rounded-full border border-zinc-200 px-3 py-1.5 text-xs text-zinc-500 dark:border-zinc-700 dark:text-zinc-400"
          role="listitem"
        >
          {tag}
        </span>
      ))
    }
  </div>
  <time
    class="relative z-10 mt-4 flex items-center text-sm text-zinc-400 dark:text-zinc-500"
    datetime={article.date}
  >
    <span
      class="mr-3 h-4 w-0.5 rounded-full bg-zinc-200 dark:bg-zinc-500"
      aria-hidden="true"></span>
    {formattedDate}
  </time>
  <h3
    class="relative z-10 mt-4 text-base font-semibold tracking-tight text-zinc-800 dark:text-zinc-100"
  >
    <a
      href={`/notes/${article.slug}`}
      class="transition hover:text-teal-600"
      data-analytics-content-id={article.slug}
      data-analytics-content-name={article.title}
      data-analytics-content-type="article"
      data-analytics-placement="article-card-title"
    >
      {article.title}
    </a>
  </h3>
  <p
    class="relative z-10 mt-2 text-sm leading-7 text-zinc-600 dark:text-zinc-400"
  >
    {article.description}
  </p>
  <span
    aria-hidden="true"
    class="relative z-10 mt-4 inline-flex items-center text-sm font-medium text-teal-600"
  >
    Read article
    <svg viewBox="0 0 16 16" fill="none" class="ml-1 h-4 w-4 stroke-current">
      <path
        d="M6.75 5.75 9.25 8l-2.5 2.25"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </span>
</article>
