---
/**
 * @file apps/web/src/components/ArticleCard.astro
 * @author Guy Romelle Magayano
 * @description Static Astro article card rendered from local article data.
 */

import type { ArticleWithSlug } from "@web/utils/articles";

type Props = {
  article: ArticleWithSlug;
};

const { article } = Astro.props;
---

<article class="rounded-lg border border-zinc-950/10 bg-white p-6">
  <div
    class="flex flex-wrap items-center gap-2"
    role="list"
    aria-label={`${article.title} tags`}
  >
    {
      (article.tags || []).slice(0, 2).map((tag) => (
        <span
          class="rounded-full border border-zinc-950/10 px-3 py-2 text-xs text-zinc-600"
          role="listitem"
        >
          {tag}
        </span>
      ))
    }
  </div>
  <h3 class="mt-4 text-xl font-medium tracking-tight text-zinc-950">
    <a href={`/articles/${article.slug}`}>{article.title}</a>
  </h3>
  <p class="mt-3 text-sm leading-7 text-zinc-600">
    {article.description}
  </p>
  <time class="mt-4 block text-sm text-zinc-500" datetime={article.date}>
    {article.date}
  </time>
</article>
