---
/**
 * @file apps/web/src/components/Footer.astro
 * @author Guy Romelle Magayano
 * @description Static Astro footer rendered directly by the site layout.
 */

import { navigationLinks, profile, socialLinks } from "@web/data/site";

const currentYear = new Date().getFullYear();
const footerLinks = navigationLinks.filter((link) => link.showInFooter);
---

<footer
  class="mt-24 border-t border-zinc-950/10 bg-zinc-950 text-white"
  aria-label="Site footer"
>
  <div class="mx-auto max-w-6xl px-6 py-10 sm:px-8">
    <div
      class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between"
    >
      <div>
        <a href="/" class="text-base font-semibold tracking-tight text-white">
          {profile.name}
        </a>
        <p class="mt-3 max-w-sm text-sm leading-6 text-zinc-400">
          {profile.role}
        </p>
      </div>

      <nav
        class="flex flex-wrap gap-x-5 gap-y-2"
        aria-label="Footer navigation"
      >
        {
          footerLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm font-medium text-zinc-300 transition hover:text-white"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="mt-8 border-t border-white/10 pt-8">
      <div
        class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between"
      >
        <p class="text-sm text-zinc-500">
          &copy; {currentYear}
          {profile.name}. All rights reserved.
        </p>
        <div class="flex flex-wrap gap-2" role="list" aria-label="Social links">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                rel={
                  link.href.startsWith("http")
                    ? "noopener noreferrer"
                    : undefined
                }
                target={link.href.startsWith("http") ? "_blank" : undefined}
                class="rounded-full border border-white/10 px-3 py-2 text-sm font-medium text-zinc-300 transition hover:border-white/30 hover:text-white"
                role="listitem"
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</footer>
