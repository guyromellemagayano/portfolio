---
/**
 * @file apps/web/src/layouts/BaseLayout.astro
 * @author Guy Romelle Magayano
 * @description Astro-first page layout with the archived template shell ported into Astro.
 */

import Footer from "@web/components/Footer.astro";
import Navbar from "@web/components/Navbar.astro";
import BaseDocument from "@web/layouts/BaseDocument.astro";
import { type WebPageMetadata } from "@web/lib/metadata.types";

type Props = {
  metadata?: WebPageMetadata;
};

const { metadata } = Astro.props;
---

<BaseDocument metadata={metadata}>
  <div class="fixed inset-0 flex justify-center sm:px-8">
    <div class="flex w-full max-w-7xl lg:px-8">
      <div
        class="w-full bg-white ring-1 ring-zinc-100 dark:bg-zinc-900 dark:ring-zinc-300/20"
      >
      </div>
    </div>
  </div>
  <div class="relative flex min-h-screen w-full flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-70 focus:rounded-full focus:bg-zinc-950 focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-white dark:focus:bg-zinc-100 dark:focus:text-zinc-950"
    >
      Skip to main content
    </a>
    <Navbar />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
  </div>
</BaseDocument>
