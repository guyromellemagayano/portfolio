---
/**
 * @file apps/web/src/layouts/BaseDocument.astro
 * @author Guy Romelle Magayano
 * @description Shared Astro document shell and metadata renderer.
 */

import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { type WebPageMetadata } from "@web/lib/metadata.types";

import "@web/styles/tailwind.css";

type Props = {
  metadata?: WebPageMetadata;
};

const { metadata } = Astro.props;
const siteName = "Guy Romelle Magayano";
const titleValue = metadata?.title;
const title =
  typeof titleValue === "string"
    ? `${titleValue} | ${siteName}`
    : titleValue?.absolute || titleValue?.default || siteName;
const description =
  metadata?.description ||
  "Portfolio of Guy Romelle Magayano, focused on product engineering, platform systems, and reusable web architecture.";
const canonicalUrl = metadata?.alternates?.canonical;
const robotsIndex = metadata?.robots?.index === false ? "noindex" : "index";
const robotsFollow = metadata?.robots?.follow === false ? "nofollow" : "follow";
const openGraph = metadata?.openGraph;
const twitter = metadata?.twitter;
const googleAnalyticsMeasurementId =
  globalThis.process?.env?.GOOGLE_ANALYTICS_MEASUREMENT_ID?.trim() ?? "";
const googleTagManagerContainerId =
  globalThis.process?.env?.GOOGLE_TAG_MANAGER_CONTAINER_ID?.trim() ?? "";
const bingSiteVerification =
  globalThis.process?.env?.BING_SITE_VERIFICATION?.trim() ?? "";
const shouldRenderVercelObservability = Boolean(
  globalThis.process?.env?.VERCEL_ENV?.trim()
);
const structuredDataItems = metadata?.structuredData
  ? Array.isArray(metadata.structuredData)
    ? metadata.structuredData
    : [metadata.structuredData]
  : [];
const googleAnalyticsBootstrapScript = googleAnalyticsMeasurementId
  ? `
window.dataLayer = window.dataLayer || [];
window.gtag = window.gtag || function gtag(...gtagArguments) {
  window.dataLayer.push(gtagArguments);
};
window.gtag("js", new Date());
window.gtag("config", ${JSON.stringify(googleAnalyticsMeasurementId)});
`
  : "";
const googleTagManagerBootstrapScript = googleTagManagerContainerId
  ? `
(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({"gtm.start":
new Date().getTime(),event:"gtm.js"});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!="dataLayer"?"&l="+l:"";j.async=true;j.src=
"https://www.googletagmanager.com/gtm.js?id="+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,"script","dataLayer",${JSON.stringify(googleTagManagerContainerId)});
`
  : "";
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="application-name" content={siteName} />
    <meta name="theme-color" content="#fafaf9" />
    {
      googleTagManagerContainerId ? (
        <script is:inline set:html={googleTagManagerBootstrapScript} />
      ) : null
    }
    {shouldRenderVercelObservability ? <Analytics /> : null}
    {shouldRenderVercelObservability ? <SpeedInsights /> : null}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteName} articles`}
      href="/rss.xml"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={`${robotsIndex},${robotsFollow}`} />
    {
      bingSiteVerification ? (
        <meta name="msvalidate.01" content={bingSiteVerification} />
      ) : null
    }
    {
      googleAnalyticsMeasurementId ? (
        <>
          <script
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(
              googleAnalyticsMeasurementId
            )}`}
          />
          <script is:inline set:html={googleAnalyticsBootstrapScript} />
          <script
            data-google-analytics-measurement-id={googleAnalyticsMeasurementId}
            defer
            src="/analytics-events.js"
          />
        </>
      ) : null
    }
    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}
    {
      openGraph?.type ? (
        <meta property="og:type" content={openGraph.type} />
      ) : null
    }
    {
      openGraph?.title ? (
        <meta property="og:title" content={openGraph.title} />
      ) : null
    }
    {
      openGraph?.description ? (
        <meta property="og:description" content={openGraph.description} />
      ) : null
    }
    {openGraph?.url ? <meta property="og:url" content={openGraph.url} /> : null}
    <meta property="og:locale" content="en_US" />
    {
      openGraph?.siteName ? (
        <meta property="og:site_name" content={openGraph.siteName} />
      ) : null
    }
    {
      openGraph?.publishedTime ? (
        <meta
          property="article:published_time"
          content={openGraph.publishedTime}
        />
      ) : null
    }
    {
      openGraph?.images?.map((image) => (
        <>
          <meta property="og:image" content={image.url} />
          {image.alt ? (
            <meta property="og:image:alt" content={image.alt} />
          ) : null}
          {image.width ? (
            <meta property="og:image:width" content={String(image.width)} />
          ) : null}
          {image.height ? (
            <meta property="og:image:height" content={String(image.height)} />
          ) : null}
        </>
      ))
    }
    {twitter?.card ? <meta name="twitter:card" content={twitter.card} /> : null}
    {
      twitter?.title ? (
        <meta name="twitter:title" content={twitter.title} />
      ) : null
    }
    {
      twitter?.description ? (
        <meta name="twitter:description" content={twitter.description} />
      ) : null
    }
    {
      twitter?.images?.map((image) => (
        <meta name="twitter:image" content={image} />
      ))
    }
    {
      structuredDataItems.map((structuredData) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(structuredData)}
        />
      ))
    }
  </head>
  <body class="flex h-full flex-col bg-stone-50 text-zinc-950">
    {
      googleTagManagerContainerId ? (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${encodeURIComponent(
              googleTagManagerContainerId
            )}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
            title="Google Tag Manager"
          />
        </noscript>
      ) : null
    }
    <slot />
  </body>
</html>
