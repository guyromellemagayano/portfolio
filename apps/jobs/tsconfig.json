{
  "extends": "@portfolio/config-typescript/src/nextjs.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "../..",
    "esModuleInterop": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "jsx": "preserve",
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@portfolio/api-contracts": [
        "../../packages/api-contracts/src/index.ts"
      ],
      "@portfolio/vitest-presets/*": [
        "../../packages/vitest-presets/*"
      ],
      "@jobs/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.css",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**"
  ]
}
